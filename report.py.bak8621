# -*- coding: utf-8 -*-
"""Генерация markdown-отчёта по результату анализа."""
from engine import SEVERITY_RU, humanize_terms

STATUS_RU = {
    'ok': 'Проверено', 'warn': 'Требует проверки', 'unknown': 'Не указано', 'fail': 'Блокирует выпуск',
    'pass': 'Проходит'
}


def _a(out, text=''):
    out.append(text)


def _clean_sentence(text):
    return str(text).strip().rstrip('.')


def _join_items(items):
    cleaned = [_clean_sentence(x) for x in (items or []) if str(x).strip()]
    return '; '.join(cleaned)



def _channel_decision(step):
    """Поясняет, почему для шага выбран конкретный способ взаимодействия.

    Отчёт должен быть понятен без знания внутренней модели: не просто
    "канал = Kafka", а "почему Kafka, а не REST/RabbitMQ/Batch".
    """
    ch = step.get('channel')
    reason = step.get('stack_reason') or ''
    writes = bool(step.get('writes_entity'))
    blocking = bool(step.get('blocking'))
    base = {
        'rest': (
            'REST API',
            'Подходит для понятного синхронного запроса, когда вызывающей стороне нужен ответ в рамках текущего сценария.',
            'Kafka/RabbitMQ не выбираются по умолчанию, потому что они разрывают сценарий во времени и требуют отдельной модели статусов. Redis не подходит как транспорт бизнес-команд. Batch/File слишком медленные для оперативного ответа.',
            'Нужны таймаут, единая модель ошибок, ограничение повторных попыток и ключ идемпотентности для операций с записью.'),
