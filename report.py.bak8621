        ('reconciliation-сверки', 'сверки'),
        ('reconciliation', 'сверка'),
        ('manual', 'ручной'),
        ('global deadline', 'общий deadline'),
        ('thundering herd', 'лавинообразный рост нагрузки'),
        ('backpressure', 'обратное давление'),
        ('retry', 'повторные попытки'),
        ('Retry', 'Повторные попытки'),
    )
    for old, new in fixes:
        out = out.replace(old, new)
    return out


def _schema_consistency_issues_v8619(steps):
    issues = []
    for st in steps:
        order = st.get('order', '?')
        name = st.get('name') or ''
        primary = _primary_channel_v8613(st)
        err = _route_error_v8620(st)
        if err:
            issues.append((order, name, err))
            continue
        if _is_outbound_external_v8619(st) and primary in {'callback', 'webhook', 'db'}:
            issues.append((order, name, 'Исходящая связь с партнёром не должна быть обратным вызовом или БД. Разделите исходящий запрос и входящий поздний результат.'))
        if _is_analytics_target_v8619(st) and primary in {'db', 'data_warehouse', 'data_lake', 'lakehouse'}:
            issues.append((order, name, 'Получатель является аналитическим контуром, а способ доставки должен быть CDC, ETL/ELT, Batch или поток событий.'))
        if (_is_observability_v8619(name) or _is_security_v8619(name) or _is_audit_v8619(name)) and not _is_cross_control_step_v8619(st):
            issues.append((order, name, 'Шаг похож на сквозной контроль и не должен искажать основную последовательность бизнес-связей.'))
    return issues

