        ('идентификатор сквозной связи/идентификатор', 'сквозной идентификатор / идентификатор'),
        ('идентификатор сквозной связи или трассировки', 'сквозной идентификатор или идентификатор трассировки'),
        ('CorrelationId или идентификатор трассировки', 'CorrelationId или traceId'),
        ('Затронутые места:', 'Затронутые места:'),
        ('». затронуто мест:', '». Затронуто мест:'),
