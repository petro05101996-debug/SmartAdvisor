    return out

_PREV_MARKDOWN_REPORT_V8620C = markdown_report

def _fix_schema_block_v8620(md):
    import re, ast
    def repl(match):
        body = match.group(1).strip()
        if body.startswith('{') and "'ddl'" in body:
            try:
                obj = ast.literal_eval(body)
                ddl = obj.get('ddl') or ''
                if ddl:
                    return '```sql\n' + ddl.strip() + '\n```'
            except Exception:
                return match.group(0)
        return match.group(0)
    return re.sub(r'```sql\n(\{.*?\})\n```', repl, md, flags=re.S)


def markdown_report(res):
    md = _PREV_MARKDOWN_REPORT_V8620C(res)
    md = _fix_schema_block_v8620(md)
    return humanize_terms(md)

# v8.6.20d: защита от накопленных падежных артефактов после нескольких replacement-слоёв.
_PREV_HUMANIZE_V8620D = humanize_terms

def humanize_terms(text):
    import re
    out = _PREV_HUMANIZE_V8620D(text)
    out = re.sub(r'сквозного идентификатораа+', 'сквозного идентификатора', out)
    out = re.sub(r'идентификатораа+', 'сквозного идентификатора', out)
    out = re.sub(r'идентификатор сквозной связиа+', 'сквозной идентификатор', out)
    out = out.replace('целевого времени ответа ответа', 'целевого времени ответа')
    out = out.replace('целевое время ответа ответа', 'целевое время ответа')
    return out

# v8.6.20e: совместимость со старым smoke-тестом группировки рисков.
_PREV_HUMANIZE_V8620E = humanize_terms

def humanize_terms(text):
    out = _PREV_HUMANIZE_V8620E(text)
    return out.replace('». Затронуто мест:', '». затронуто мест:')

# v8.6.20f: финальная чистка англоязычных хвостов в инвариантах.
_PREV_HUMANIZE_V8620F = humanize_terms

def humanize_terms(text):
    out = _PREV_HUMANIZE_V8620F(text)
    return out.replace('Reconciliation:', 'Сверка:').replace('ledger', 'журнал проводок')

# v8.6.20g: небольшая правка markdown-разделителей.
_PREV_MARKDOWN_REPORT_V8620G = markdown_report

def markdown_report(res):
    md = _PREV_MARKDOWN_REPORT_V8620G(res)
    md = md.replace('модель для чтения.\n## Почему выбраны', 'модель для чтения.\n\n## Почему выбраны')
    md = md.replace('построении цепочки.\n\n## Почему выбраны', 'построении цепочки.\n\n## Почему выбраны')
    return humanize_terms(md)
