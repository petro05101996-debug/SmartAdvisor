    return {'technology': name, 'why': humanize_terms(why), 'why_not': humanize_terms(why_not), 'controls': humanize_terms(controls)}


def _pattern_tradeoff(pattern):
    name = str(pattern.get('name', ''))
    pid = str(pattern.get('id', ''))
    text = (pid + ' ' + name).lower()
    if 'outbox' in text or 'исходящих' in text:
        return ('Паттерн нужен, чтобы запись в БД и отправка сообщения не расходились между собой.',
                'Без него возможна ситуация: данные уже записаны, а событие не отправилось, или событие ушло без надёжной фиксации данных.')
    if 'inbox' in text or 'идемпотент' in text or 'дедуп' in text:
        return ('Паттерн нужен, потому что повторная доставка сообщения или обратного вызова является нормальным сценарием.',
                'Без него дубль может повторно изменить статус, создать вторую операцию или испортить историю процесса.')
    if 'saga' in text or 'компенсац' in text:
        return ('Паттерн нужен, когда операция состоит из нескольких систем и не может быть закрыта одной общей транзакцией.',
                'Обычная транзакция БД не работает между внешними системами; поэтому нужны состояния, компенсации и ручной разбор спорных случаев.')
    if 'circuit' in text or 'предохран' in text:
        return ('Паттерн нужен, чтобы отказ внешнего сервиса не ронял весь процесс и не создавал лавину повторов.',
                'Без него система будет продолжать давить на деградирующую зависимость и ухудшать аварию.')
    if 'audit' in text or 'аудит' in text:
        return ('Паттерн нужен, чтобы можно было доказать, кто, когда и почему изменил юридически или финансово значимые данные.',
                'Обычного текущего статуса недостаточно: он не объясняет историю изменений и не помогает в споре или расследовании.')
    if 'reconciliation' in text or 'свер' in text:
        return ('Паттерн нужен, чтобы регулярно доказывать полноту обработки и находить расхождения между системами.',
                'Без сверки часть ошибок обнаружится только по жалобе клиента, отчёту или инциденту.')
    return ('Паттерн предлагается, потому что он закрывает один или несколько найденных рисков в этой цепочке.',
            'Если его не применять, нужно явно описать другой механизм с теми же гарантиями.')


def _alternative_rationale(alt):
    name = str(alt.get('name', '')).lower()
    if 'миним' in name:
        return ('Этот вариант выбран как быстрый способ снизить самые опасные риски без полной перестройки процесса.',
                'Он не является целевой архитектурой: часть технического долга останется, поэтому его нельзя считать финальным решением для высокой нагрузки или регуляторного сценария.')
    if 'целев' in name or 'рекоменду' in name:
        return ('Этот вариант выбран как более устойчивое решение для промышленной эксплуатации, где важны восстановление, наблюдаемость и управляемое внедрение.',
                'Он дороже минимального варианта, но снижает риск скрытых дублей, потери событий, ручных аварийных исправлений и неуправляемого отката.')
    if 'компром' in name:
        return ('Этот вариант выбран как баланс между сроками, стоимостью и уровнем надёжности.',
                'Он хуже целевого варианта по запасу прочности, но безопаснее минимального исправления, если закрыть явно перечисленные ограничения.')
    return ('Вариант предлагается как один из допустимых путей закрытия найденных рисков.',
            'Выбирать его можно только после проверки ограничений проекта: сроки, стоимость, доступный стек, команда сопровождения и требования регулятора.')




def _plain_or_unknown(value, fallback='не указано'):
    value = humanize_terms(value or '').strip()
    return value or fallback


def _route_label(step):
    source = _plain_or_unknown(step.get('source_system'), 'источник не указан')
    actor = _plain_or_unknown(step.get('system'), 'исполнитель не указан')
    target = _plain_or_unknown(step.get('target_system'), 'получатель не указан')
    if source == actor and actor == target:
        return f"участник: {actor}"
    if source == actor:
        return f"{actor} → {target}"
    if actor == target:
        return f"{source} → {actor}"
    return f"{source} → {actor} → {target}"


def _dependency_label(step, steps_by_order=None):
    deps = step.get('deps') or []
    if not deps and step.get('depends_on') not in (None, '', 0, '0'):
        deps = [step.get('depends_on')]
    names = []
    for dep in deps:
        try:
            dep_i = int(dep)
        except Exception:
            continue
        if dep_i <= 0:
            continue
        dep_step = (steps_by_order or {}).get(dep_i)
        if dep_step:
            names.append(f"шаг {dep_i} «{_clean_sentence(humanize_terms(dep_step.get('name', '')))}»")
        else:
            names.append(f"шаг {dep_i}")
    return ', '.join(names) if names else 'начало процесса или внешний запуск'


def _human_top_summary(res):
    model = res.get('model') or {}
    meta = model.get('meta') or {}
    steps = model.get('steps') or []
    systems = model.get('systems') or []
    verdict = res.get('verdict') or {}
    groups = _finding_groups(res)
    serious = [g for g in groups if g.get('severity') in ('critical', 'high')]
    main_risks = []
    for g in serious[:3]:
        title = _clean_sentence(humanize_terms(g.get('title', '')))
        where = _clean_sentence(humanize_terms(g.get('where_summary') or g.get('where') or ''))
        if title:
            main_risks.append((title, where))
    what = (f"Процесс «{meta.get('name', 'без названия')}» описан как цепочка из {len(steps)} взаимодействий "
            f"между {len(systems)} участниками. Система оценила архитектурную готовность как "
            f"{verdict.get('score', 'не рассчитано')}/10: {verdict.get('verdict', 'вердикт не рассчитан')}.")
    if main_risks:
        where_bits = []
        for title, where in main_risks:
            if where:
                where_bits.append(f"{title} — в зоне: {where}")
            else:
                where_bits.append(title)
        where_text = 'Основные проблемные места: ' + '; '.join(where_bits) + '.'
        why_text = ('Эти места важны, потому что именно там выше риск потери данных, дублей, зависания статуса, '
                    'неуправляемых повторных попыток или непонятного восстановления после сбоя.')
    else:
        where_text = 'Критичных проблемных мест по правилам проверки не найдено.'
        why_text = ('Это не отменяет ревью контрактов, нагрузочного профиля, безопасности и эксплуатационных процедур, '
                    'но базовая цепочка выглядит согласованной.')
    return what, where_text, why_text


def _human_step_decision(step, decision, steps_by_order=None):
    order = step.get('order', '?')
    name = _clean_sentence(humanize_terms(step.get('name', 'действие без названия')))
    technology = humanize_terms(decision.get('technology', 'способ не определён'))
    route = _route_label(step)
    dependency = _dependency_label(step, steps_by_order)
    timing = 'с ожиданием ответа сразу' if step.get('blocking') else 'без ожидания немедленного ответа'
    what = f"**Что:** в шаге {order} «{name}» предлагается использовать {technology}."
    where = f"**Где:** это применяется на связи {route}; шаг выполняется после: {dependency}; характер взаимодействия — {timing}."
    why = f"**Почему:** {humanize_terms(decision.get('why', '')).strip()}"
    why_not = f"**Почему не другой вариант:** {humanize_terms(decision.get('why_not', '')).strip()}"
    controls = f"**Что проверить перед выпуском:** {humanize_terms(decision.get('controls', '')).strip()}"
    return [what, where, why, why_not, controls]


def _human_finding_line(group):
    title = _clean_sentence(humanize_terms(group.get('title', 'риск без названия')))
    where = _clean_sentence(humanize_terms(group.get('where_summary') or group.get('where') or 'место не указано'))
    why = _clean_sentence(humanize_terms(group.get('why', 'причина не указана')))
    fix = _clean_sentence(humanize_terms(group.get('fix', 'действие не указано')))
    return (f"- **Что:** {title}.\n"
            f"  **Где:** {where}.\n"
            f"  **Почему важно:** {why}.\n"
            f"  **Что нужно сделать:** {fix}.")

def _humanize_markdown_lines(lines):
    out = []
    in_code = False
    for line in lines:
        if str(line).startswith('```'):
            out.append(line)
            in_code = not in_code
            continue
        out.append(line if in_code else humanize_terms(line))
    return '\n'.join(out)

def _finding_groups(res):
    if res.get('finding_groups'):
        return res['finding_groups']
    groups = []
    for f in res.get('findings', []):
        groups.append({**f, 'count': 1, 'affected': [f.get('where', '')],
                       'where_summary': f.get('where', ''), 'where': f.get('where', '')})
    return groups


def _affected_lines(group, limit=20):
    affected = [x for x in (group.get('affected') or []) if str(x).strip()]
    if not affected:
        return []
    lines = affected[:limit]
    if len(affected) > limit:
        lines.append(f'Ещё затронуто мест: {len(affected) - limit}.')
    return lines


def markdown_report(res):
    m = res['model']['meta']
    g = res['model']['graph']
    v = res['verdict']
    comp = res.get('completeness') or {'summary': 'Полнота вводных не рассчитана.', 'missing': []}
    gates = res.get('quality_gates') or {'readiness': 'не рассчитано', 'gates': []}
    checklist = res.get('checklist') or {'items': [], 'counters': {}}
    artifacts = res.get('artifacts') or {}
    groups = _finding_groups(res)
    out = []
    a = lambda text='': _a(out, text)

    a(f"# Архитектурный разбор: {m['name']}")
    a('')
    grouped_counts = v.get('group_counts') or {}
    if grouped_counts:
        a(f"**Итоговый вывод:** {v['verdict']} Оценка архитектурной готовности: {v['score']}/10. "
          f"Найдено классов рисков: критичных — {grouped_counts.get('critical', 0)}, "
          f"высоких — {grouped_counts.get('high', 0)}, средних — {grouped_counts.get('medium', 0)}. "
          f"Всего отдельных срабатываний правил: {sum(v['counts'].values())}.")
    else:
        a(f"**Итоговый вывод:** {v['verdict']} Оценка архитектурной готовности: {v['score']}/10. "
          f"Найдено критичных рисков: {v['counts']['critical']}, высоких рисков: {v['counts']['high']}, "
          f"средних рисков: {v['counts']['medium']}.")
    a(f"**Готовность к промышленному запуску:** {gates.get('readiness', 'не рассчитано')}. "
      f"**{comp.get('summary', '')}**")
    a('')

    what, where_text, why_text = _human_top_summary(res)
    a('## Короткий человеческий вывод')
    a('')
    a(f"**Что:** {what}")
    a(f"**Где:** {where_text}")
    a(f"**Почему:** {why_text}")
    a('')
    a('**Что делать дальше:** сначала проверьте проблемные места из этого вывода, затем уточните недостающие вводные, после этого согласуйте стек по каждой связи и только потом переводите решение в постановку на разработку.')
    a('')

    if m['goal']:
        a(f"**Бизнес-цель:** {m['goal']}")
    a(f"**Основная сущность:** {m['entity']}. "
      f"Деньги: {m['money']}. Регуляторика: {'да' if m['regulatory'] else 'нет'}. "
      f"Клиентский сценарий: {'да' if m['customer_visible'] else 'нет'}.")
    if m['sla_ms']:
        a(f"**Требование ко времени ответа:** {m['sla_ms']} мс; бюджет таймаутов критического пути: "
          f"{g['critical_budget_ms']} мс.")
    a('')

    a('## Почему выбраны технологии и способы взаимодействия')
    a('')
    a('Ниже каждое решение описано по схеме «что / где / почему». Сначала читайте карточки: они объясняют решение человеческим языком. Таблица после карточек нужна как сжатая проверочная версия для архитектурного ревью.')
    a('')
    steps_by_order = {int(st.get('order')): st for st in res['model']['steps'] if str(st.get('order', '')).isdigit()}
    a('### Объяснение по шагам')
    a('')
    for step in res['model']['steps']:
        decision = _channel_decision(step)
        a(f"#### Шаг {step.get('order', '?')}. {_clean_sentence(humanize_terms(step.get('name', 'действие без названия')))}")
        a('')
        for line in _human_step_decision(step, decision, steps_by_order):
            a(line)
        a('')

    a('### Таблица для быстрой проверки')
    a('')
    a('| Шаг | Технология / способ | Почему выбрано | Почему не другой вариант | Обязательные условия |')
    a('|---|---|---|---|---|')
    for step in res['model']['steps']:
        decision = _channel_decision(step)
        route = ''
        if step.get('source_system') or step.get('target_system'):
            route = f" Маршрут: {step.get('source_system') or 'источник не указан'} → {step.get('system') or 'исполнитель не указан'} → {step.get('target_system') or 'получатель не указан'}."
        title = f"{step['order']}. {_clean_sentence(humanize_terms(step['name']))}.{route}"
        a(f"| {title} | {decision['technology']} | {decision['why']} | {decision['why_not']} | {decision['controls']} |")
    a('')

    a('## Как читать предложенное решение')
    a('')
    a('Почему предлагается именно так: решение выбирается из смысла связи и уточнений пользователя. Почему нельзя просто не делать: без выбранных гарантий процесс может терять данные, создавать дубли или становиться неразбираемым при сбое. Если в отчёте предлагается технология, паттерн или изменение процесса, рядом должно быть объяснение: какую проблему оно закрывает, почему простой вариант недостаточен и какие проверки нужны перед промышленным запуском. Если команда выбирает другой стек, она должна сохранить те же гарантии: идемпотентность, восстановление, наблюдаемость, контроль дублей, безопасность входящих вызовов и понятный план отката.')
    a('')

    a('## Контрольные проверки готовности к промышленному запуску')
    a('')
    if gates.get('gates'):
        a('| Проверка | Статус | Что мешает выпуску | Что нужно уточнить |')
        a('|---|---|---|---|')
        for gate in gates['gates']:
            fail = _join_items(gate.get('fail') or []) or '—'
            warn = _join_items(gate.get('warn') or []) or '—'
            a(f"| {gate['name']} | {STATUS_RU.get(gate['status'], gate['status'])} | {fail} | {warn} |")
    else:
        a('Контрольные проверки готовности к промышленному запуску не рассчитаны.')
    a('')

    a('## Какие вводные нужно уточнить')
    a('')
    if comp.get('missing'):
        a('| Приоритет | Область | Что нужно уточнить | Почему это важно |')
        a('|---|---|---|---|')
        for item in comp['missing']:
            a(f"| {item['priority']} | {item['area']} | {item['question']} | {item['why']} |")
    else:
        a('Критичных пропусков во вводных не найдено. При этом архитектурное ревью и согласование контрактов всё равно нужны.')
    a('')

    a('## Обязательный архитектурный чек-лист')
    a('')
    if checklist.get('items'):
        a('| Область | Статус | Что проверяется | Как закрыть пункт |')
        a('|---|---|---|---|')
        for item in checklist['items']:
            a(f"| {item['area']} | {STATUS_RU.get(item['status'], item['status'])} | "
              f"{_clean_sentence(item['title'])}. {item['check']} | {item['fix']} |")
    else:
        a('Архитектурный чек-лист не рассчитан.')
    a('')


    radar = res.get('detail_radar') or {'summary': 'Матрица деталей не рассчитана.', 'probes': []}
    a('## Матрица деталей, которые нельзя забыть')
    a('')
    a(radar.get('summary', 'Матрица деталей не рассчитана.'))
    a('')
    if radar.get('probes'):
        a('| Область | Статус | Что проверить | Почему это важно | Как закрыть |')
        a('|---|---|---|---|---|')
        for item in radar['probes']:
            examples = ''
            if item.get('examples'):
                examples = ' Примеры: ' + '; '.join(item.get('examples') or []) + '.'
            a(f"| {item['area']} | {STATUS_RU.get(item['status'], item['status'])} | "
              f"{_clean_sentence(item['title'])}. {item['question']} | {item['why']} | {item['how']}{examples} |")
    else:
        a('Матрица деталей не рассчитана.')
    a('')

    a('## Варианты архитектурного решения')
    a('')
    for alt in res.get('alternatives', []):
        a(f"### {alt['name']}")
        a('')
        a(f"Этот вариант подходит, когда {alt['when']}")
        a(f"Оценка варианта: стоимость — {alt['cost']}; надёжность — {alt['reliability']}; риск — {alt['risk']}.")
        why_alt, why_not_alt = _alternative_rationale(alt)
        a(f"Почему предлагается именно так: {why_alt}")
        a(f"Почему это не универсальный ответ: {why_not_alt}")
        a('')
        a('В вариант нужно включить следующие изменения:')
        for c in alt.get('changes', []):
            a(f"- {c}")
        if alt.get('must_close'):
            a('')
            a(f'Перед внедрением обязательно закрыть блокеры из раздела «Найденные риски». Количество классов блокеров: {len(alt["must_close"])}.')
        a('')
        a(alt.get('not_enough', ''))
        a('')

    scenario = res.get('scenario') or {}
    a('## Сценарная основа для дальнейшей разработки')
    a('')
    if scenario:
        if scenario.get('statuses'):
            a('**Рекомендуемая статусная модель:** ' + ', '.join(scenario.get('statuses', [])) + '.')
            a('')
        a('### Основной сценарий')
        a('')
        for st in scenario.get('main_flow', []):
            a(f"{st['order']}. **{st['title']}**")
            a(f"   - Что происходит: {st['what_happens']}")
            a(f"   - Способ взаимодействия: {st.get('channel_label', st.get('channel', 'не указан'))}.")
            if st.get('stack_reason'):
                a(f"   - Почему выбран такой способ: {humanize_terms(st.get('stack_reason'))}")
            a(f"   - Зависимость: {st['depends_on']}.")
            a(f"   - Результат: {st['result']}")
            if st.get('controls'):
                a('   - Контроли: ' + '; '.join(st['controls']) + '.')
            a(f"   - При ошибке: {st['failure_handling']}")
        a('')
        if scenario.get('alternative_flows'):
            a('### Альтернативные сценарии')
            a('')
            for i, alt in enumerate(scenario.get('alternative_flows', []), 1):
                a(f"{i}. **{alt['name']}**")
                a(f"   - Когда возникает: {alt['trigger']}")
                for step_text in alt.get('steps', []):
                    a(f"   - {step_text}")
                a(f"   - Ожидаемый результат: {alt['result']}")
                a('   - Обязательные контроли: ' + '; '.join(alt.get('controls', [])) + '.')
                a('')
        if scenario.get('error_flows'):
            a('### Ошибочные сценарии, которые нужно учесть')
            a('')
            for i, err in enumerate(scenario.get('error_flows', []), 1):
                affected = f" Затронуто мест: {err.get('affected_count')}" if err.get('affected_count', 1) > 1 else ''
                a(f"{i}. **{err['name']}** — {err['where']}.{affected}")
                a(f"   - Что может пойти не так: {err['failure']}")
                a(f"   - Как должно обрабатываться: {err['expected_handling']}")
        a('')
        if scenario.get('development_tasks'):
            a('### Что перенести в постановку на разработку')
            a('')
            for t in scenario.get('development_tasks', []):
                a(f"- {t}")
            a('')
        if scenario.get('acceptance_criteria'):
            a('### Критерии приёмки')
            a('')
            for t in scenario.get('acceptance_criteria', []):
                a(f"- {t}")
            a('')
    else:
        a('Сценарная основа не рассчитана.')
        a('')

    a('## Карта процесса и последовательность взаимодействий')
    a('')
    a('```mermaid')
    a(res['diagrams']['flow'])
    a('```')
    a('')
    a('```mermaid')
    a(res['diagrams']['sequence'])
    a('```')
    a('')

    a('## Найденные риски и слабые места')
    a('')
    a('Риски ниже тоже описаны по схеме «что / где / почему / что сделать», чтобы их можно было сразу перенести в обсуждение с командой или в постановку.')
    a('')
    if not groups:
        a('Структурных проблем не обнаружено. Это не отменяет архитектурное ревью, код-ревью, контрактные проверки и нагрузочные тесты.')
    last_sev = None
    for f in groups:
        if f['severity'] != last_sev:
            last_sev = f['severity']
            a(f"### {SEVERITY_RU[f['severity']]}")
            a('')
        suffix = f" (затронуто мест: {f.get('count', 1)})" if f.get('count', 1) > 1 else ''
        for line in _human_finding_line(f).split('\n'):
            if suffix and line.startswith('- **Что:**'):
                line = line + suffix
            a(line)
        affected = _affected_lines(f)
        if f.get('count', 1) > 1 and affected:
            a('Затронутые места:')
            for w in affected:
                a(f"- {humanize_terms(w)}")
        a('')

    a('## Рекомендуемые архитектурные паттерны')
    a('')
    if not res['patterns']:
        a('Дополнительные архитектурные паттерны не требуются по текущим вводным.')
    for p in res['patterns']:
        why_pattern, why_not_pattern = _pattern_tradeoff(p)
        a(f"**{p['name']}.**")
        a('')
        a(f"Почему предлагается: {humanize_terms(p['why'])} {why_pattern}")
        a('')
        a(f"Почему нельзя просто не делать: {why_not_pattern}")
        a('')
        a('Обязательные контроли для паттерна: ' + '; '.join(humanize_terms(x) for x in p['controls']) + '.')
        a('')

    a('## Предлагаемая структура базы данных')
    a('')
    a('В проекте могут понадобиться следующие таблицы: ' + ', '.join(res['schema']['tables']) + '.')
    a('')
    a('```sql')
    a(res['schema']['ddl'])
    a('```')
    a('')

    a('## Готовность к началу разработки')
    a('')
    for i in artifacts.get('definition_of_ready', []):
        a(f"- {i}")
    a('')

    a('## Готовность к выпуску')
    a('')
    for i in artifacts.get('definition_of_done', []):
        a(f"- {i}")
    a('')

    a('## Мониторинг и эксплуатационные метрики')
    a('')
    for i in artifacts.get('monitoring', []):
        a(f"- {i}")
    a('')

    if artifacts.get('event_contract_skeleton'):
        a('## Черновик контракта события')
        a('')
        a('```json')
        a('{')
        sk = artifacts['event_contract_skeleton']
        for idx, (k, desc) in enumerate(sk.items()):
            comma = ',' if idx < len(sk) - 1 else ''
            a(f'  "{k}": "{desc}"{comma}')
        a('}')
        a('```')
        a('')

    a('## Чек-лист проверок и тестов')
    a('')
    for i, t in enumerate(res['tests'], 1):
        a(f"{i}. {t}")
    a('')

    crit_high = [f for f in groups if f['severity'] in ('critical', 'high')]
    a('## План внедрения и безопасного вывода в промышленную эксплуатацию')
    a('')
    a('**Этап 1 — обязательный минимум перед разработкой:** закройте все критичные и высокие классы рисков, а также проваленные контрольные проверки готовности — '
      + ('; '.join(f['title'] for f in crit_high) + '.' if crit_high
         else 'критичных и высоких рисков нет, можно начинать с целевой схемы.'))
    a('')
    a('**Этап 2 — усиление перед промышленным запуском:** закройте пункты со статусами «не указано» и «требует проверки» чек-листа: контракты, '
      'наблюдаемость, повторная обработка, срок хранения, сверка, нагрузочный тест.')
    a('')
    a('**Этап 3 — эксплуатация:** подготовьте инструкцию разбора инцидентов, регулярную сверку, обучение поддержки и '
      'проверку повторной обработки и отката на регламентной основе.')
    a('')
    return _humanize_markdown_lines(out)

# v8.5.9: переопределение пояснений по стеку.
# Старый расширенный каталог покрывал технологии, но часть новых пунктов объяснялась слишком общими словами.
# Этот вариант даёт конкретное объяснение: почему выбрано, почему не альтернатива, что обязательно проверить.
def _channel_decision(step):
    ch = step.get('channel')
    decisions = {
        'rest': ('REST API',
            'Подходит для синхронного запроса по HTTP: система отправляет запрос и должна получить ответ в рамках текущего сценария.',
            'SOAP нужен в основном при старом WSDL/XML-контракте. Kafka, RabbitMQ и другие брокеры разрывают сценарий во времени и подходят, когда ответ не нужен сразу.',
            'Нужны таймаут, лимит повторных попыток, единая модель ошибок, трассировка и ключ идемпотентности для операций с записью.'),
        'graphql': ('GraphQL',
            'Подходит для гибкого чтения, когда разные клиенты хотят получать разные наборы полей и не нужен отдельный REST-метод под каждую форму экрана.',
            'REST проще для стабильных команд и фиксированных ресурсов. GraphQL хуже, если нет контроля сложности запроса и прав на уровне полей.',
            'Нужны авторизация полей, лимит глубины/сложности запроса, пагинация, защита от тяжёлых запросов и понятный контракт схемы.'),
        'odata': ('OData',
            'Подходит для корпоративного API по сущностям, где нужны стандартные фильтры, сортировка, выбор полей и интеграция с enterprise-инструментами.',
            'REST проще для произвольных команд. GraphQL гибче для клиентских экранов, но хуже вписывается в контур, где уже принят OData-подход к сущностям.',
            'Нужны ограничения фильтров, права на поля, лимит размера ответа, версионирование сущностей и аудит доступа.'),
        'grpc': ('gRPC',
            'Подходит для быстрого внутреннего вызова между сервисами при стабильном контракте и требовании низкой задержки.',
            'REST проще для внешних потребителей. Kafka/RabbitMQ не подходят, если вызывающий сервис должен получить ответ сразу.',
            'Нужны общий срок ожидания, контракт Protobuf, совместимость версий, retries только для безопасных операций и обработка недоступности сервиса.'),
        'soap': ('SOAP',
            'Подходит для старых корпоративных систем, если уже есть WSDL/XSD-контракт, XML-сообщения и регламент обмена через SOAP.',
            'REST/gRPC проще для новых API, но могут быть невозможны без доработки старой системы. Брокер сообщений не заменит существующий синхронный SOAP-вызов.',
            'Нужны версии XSD, описание SOAP Fault, таймауты, логирование исходного XML, маскирование чувствительных данных и регламент повторов.'),
        'api_gateway': ('API Gateway',
            'Нужен как единая внешняя точка входа: авторизация, лимиты запросов, маршрутизация, версия API и защита периметра.',
            'Прямой вызов внутреннего сервиса раскрывает внутреннюю структуру и размазывает безопасность по сервисам. Брокеры не являются публичным входом для клиентского API.',
            'Нужны проверка токена, лимиты запросов, трассировка, единая модель ошибок и запрет обхода шлюза.'),
        'service_mesh': ('Service Mesh',
            'Подходит для управления внутренними вызовами: взаимная TLS-аутентификация, политики трафика, ретраи, трассировка и постепенное переключение версий.',
            'API Gateway закрывает внешний периметр, но не управляет всем внутренним service-to-service трафиком. Ручная настройка в каждом сервисе быстро расходится.',
            'Нужны владельцы mesh-политик, лимиты retry, mTLS, наблюдаемость, правила canary/traffic split и план аварийного обхода.'),
        'esb': ('Интеграционная шина ESB',
            'Подходит, когда нужно связать несколько старых или корпоративных систем, выполнить маршрутизацию и преобразование форматов.',
            'Прямые REST-вызовы увеличивают связанность систем. Kafka хороша для событий, но не всегда заменяет трансформации, оркестрацию и legacy-маршруты в enterprise-контуре.',
            'Нужны владелец маршрутов, версии трансформаций, трассировка, контроль ошибок преобразования и идемпотентность.'),
        'db': ('Основная база данных',
            'Подходит для фиксации состояния процесса, статусов, ключей идемпотентности, истории и технического журнала шагов.',
            'Redis не должен быть источником истины. Kafka/RabbitMQ передают сообщения, но не заменяют надёжную операционную запись. DWH не подходит для оперативной транзакции.',
            'Нужны транзакции, уникальные индексы, версия записи или optimistic locking, сроки хранения и план очистки технических таблиц.'),
        'read_replica': ('Реплика базы данных для чтения',
            'Подходит, если чтений много и нужно разгрузить основную БД без изменения модели записи.',
            'Кэш быстрее, но может устаревать и требует инвалидации. Шардирование сложнее и нужно, когда уже не хватает разделения по нагрузке/объёму.',
            'Нужны контроль задержки репликации, маршрутизация read-only запросов, fallback на основную БД и запрет операций записи в реплику.'),
        'db_sharding': ('Шардирование базы данных',
            'Подходит, когда объём данных или запись по одному хранилищу уже не масштабируется и есть естественный ключ разделения.',
            'Реплика чтения разгружает только read-нагрузку. Кэш не решает рост записи и объёма. Шардирование нельзя вводить без ключа доступа и стратегии ребалансировки.',
            'Нужны ключ шардинга, правила ребалансировки, ограничения cross-shard запросов, миграция данных и тесты горячих ключей.'),
        'mongodb': ('Документное хранилище',
            'Подходит для гибких документов и меняющейся структуры, когда сущность удобнее хранить как документ, а не как набор жёстких таблиц.',
            'Реляционная БД лучше для строгих связей, транзакций и отчётности по нормализованной модели. Key-value проще, но хуже для сложного документа и индексов по полям.',
            'Нужны схема документа, индексы, правила миграции структуры, лимит размера документа и стратегия консистентности.'),
        'cassandra': ('Cassandra/ScyllaDB',
            'Подходит для очень больших распределённых записей по ключу, высокой записи и предсказуемых запросов по partition key.',
            'Реляционная БД проще для транзакций и ad-hoc запросов. MongoDB удобнее для документов. Cassandra плоха, если заранее неизвестны ключи доступа.',
            'Нужны partition key, clustering key, уровень консистентности, TTL, repair/compaction и проверка hot partition.'),
        'dynamodb': ('Хранилище ключ-значение',
            'Подходит для быстрого доступа по ключу в управляемом key-value/NoSQL-хранилище с предсказуемыми access patterns.',
            'Реляционная БД лучше для сложных связей и транзакционных запросов. Cassandra чаще выбирается для self-hosted распределённой модели. Redis не источник истины для долговременных бизнес-данных.',
            'Нужны partition key, sort key, conditional write, TTL, лимиты throughput и защита от hot keys.'),
        'clickhouse': ('Колоночная аналитическая база данных',
            'Подходит для быстрой аналитики по большим таблицам, агрегаций, витрин и отчётов по событиям.',
            'Операционная БД не должна выполнять тяжёлую аналитику. DWH шире по назначению, но ClickHouse удобен для быстрых аналитических запросов и логовых витрин.',
            'Нужны партиционирование, ключ сортировки, контроль свежести, политика хранения и сверка с источником.'),
        'data_warehouse': ('Аналитическое хранилище',
            'Подходит как слой согласованных витрин и отчётности, когда данные нужны аналитикам, регуляторным отчётам или управленческим показателям.',
            'Операционная БД не должна становиться местом тяжёлых отчётов. Data Lake хранит сырьё шире, но без модели витрин отчётность будет менее управляемой.',
            'Нужны модель данных, расписание загрузки, контроль полноты, lineage, владельцы витрин и сверка с источниками.'),
        'data_lake': ('Озеро данных',
            'Подходит для хранения сырых данных разных форматов: файлов, событий, логов, документов и исторических выгрузок.',
            'DWH лучше для очищенных витрин и регулярной отчётности. Object Storage хранит файлы, но само по себе не задаёт зоны данных, каталог и правила обработки.',
            'Нужны raw/clean/curated зоны, каталог данных, права доступа, формат хранения, контроль качества и срок хранения.'),
        'lakehouse': ('Lakehouse',
            'Подходит, когда нужно совместить хранение сырья как в озере данных и табличную аналитику с транзакционными таблицами.',
            'DWH удобнее для классической отчётности, Data Lake проще для сырья, но Lakehouse полезен, когда нужны оба сценария в одном контуре.',
            'Нужны формат таблиц, compaction, контроль схем, права доступа, каталог, freshness и стратегия отката изменений.'),
        'redis_cache': ('Redis как кэш',
            'Подходит для ускорения чтения часто используемых данных, если потеря кэша не разрушает бизнес-состояние.',
            'БД остаётся источником истины. Kafka/RabbitMQ не ускоряют чтение текущего состояния. Redis lock нужен для блокировки, а не для чтения данных.',
            'Нужны TTL, инвалидация, защита от лавины обращений к источнику и запасной сценарий чтения из БД/источника.'),
        'memcached': ('Memcached как простой временный кэш',
            'Подходит для простого временного кэша без сложных структур, когда нужна высокая скорость чтения и допустима потеря кэша.',
            'Redis богаче по структурам данных и сценариям блокировок/streams. БД остаётся источником истины, но не должна держать весь горячий read-трафик.',
            'Нужны TTL, стратегия инвалидации, fallback к источнику, лимит размера значений и защита от cache stampede.'),
        'redis_lock': ('Redis как распределённая блокировка',
            'Подходит для короткой защиты критической секции, когда нельзя параллельно выполнять операцию по одной сущности.',
            'Кэш Redis не решает взаимное исключение. БД-lock может быть надёжнее для финансовой записи, но дороже и сильнее нагружает БД. Kafka сама по себе не блокирует критическую секцию.',
            'Нужны TTL, защитный токен блокировки, безопасное освобождение и обработка зависшего процесса.'),
        'search': ('Поисковый индекс',
            'Подходит для полнотекстового поиска, фильтрации по многим полям и быстрых пользовательских выборок.',
            'БД может быть источником истины, но не всегда удобна для полнотекстового поиска. Redis ускоряет чтение по ключу, но не заменяет поисковый индекс.',
            'Нужны переиндексация, контроль отставания индекса, правила актуализации и понятная свежесть данных для пользователя.'),
        'vector_db': ('Векторное хранилище',
            'Подходит для семантического поиска по текстам, похожих документов, эмбеддингов и сценариев поиска по смыслу.',
            'Обычный search лучше для точных фильтров и полнотекста. Реляционная БД не предназначена как основной движок similarity search.',
            'Нужны модель эмбеддингов, версия векторов, переиндексация, контроль качества поиска и правила доступа к исходным текстам.'),
        'kafka': ('Kafka',
            'Подходит для потока событий, высокой нагрузки, повторной обработки, хранения истории событий и рассылки нескольким потребителям.',
            'REST не подходит, если потребителей несколько и результат не нужен немедленно. RabbitMQ проще для очереди задач, но хуже как долговременный журнал событий. Redis Streams легче, но обычно слабее для критичного event log.',
            'Нужны topic, ключ партиционирования, группа потребителей, срок хранения, очередь ошибочных сообщений или карантин и инструкция повторной обработки.'),
        'pulsar': ('Pulsar',
            'Подходит для масштабного потока событий, когда нужны независимое хранение, много подписок, разделение хранения и вычисления или сложная multi-tenant модель.',
            'Kafka чаще проще найти в командах и инфраструктуре. RabbitMQ лучше для очереди задач. Pulsar стоит выбирать, когда его преимущества реально нужны и команда умеет его сопровождать.',
            'Нужны tenant/namespace/topic, retention, backlog, subscription type, ключ порядка, мониторинг backlog и план эксплуатации BookKeeper/хранилища.'),
        'rabbitmq': ('RabbitMQ',
            'Подходит для очереди задач, маршрутизации, подтверждения обработки, ограниченного числа worker-ов и сценариев task queue.',
            'Kafka лучше для event log, replay и большого числа независимых потребителей. REST не выравнивает нагрузку между worker-ами. Redis queue проще, но слабее для критичных процессов.',
            'Нужны exchange, routing key, очередь, подтверждение обработки, dead-letter exchange, prefetch и лимит повторов.'),
        'activemq': ('ActiveMQ/Artemis',
            'Подходит для корпоративной JMS-очереди, если в организации уже используется Java/JMS-контур и нужны стандартные enterprise-возможности очередей.',
            'RabbitMQ обычно проще для современных task queue. Kafka лучше для event log. IBM MQ выбирают, если уже есть строгий мейнфрейм/банковский MQ-контур.',
            'Нужны модель подтверждения, durable queues/topics, DLQ, транзакционность при необходимости и мониторинг потребителей.'),
        'ibm_mq': ('IBM MQ',
            'Подходит для гарантированного корпоративного обмена в банках/enterprise/мейнфрейм-контуре, где IBM MQ уже является стандартом.',
            'RabbitMQ проще и дешевле для новых очередей задач. Kafka лучше для событийного журнала. IBM MQ выбирают из-за совместимости, регламента и требований надёжности старого контура.',
            'Нужны queue manager, каналы, права, persistent messages, DLQ, мониторинг глубины очередей и регламент разбора зависших сообщений.'),
        'nats': ('NATS',
            'Подходит для лёгкой внутренней рассылки сообщений с малой задержкой, когда нужна простая pub/sub-модель без тяжёлого брокера.',
            'Kafka лучше для долговременного журнала и replay. RabbitMQ лучше для надёжной очереди задач. NATS выбирается, когда важна простота и скорость, а не длительное хранение событий.',
            'Нужны subject-ы, правила подписки, допустимость потерь/JetStream при необходимости, мониторинг и ограничения размера сообщений.'),
        'sns_sqs': ('AWS SNS/SQS',
            'Подходит для облачной очереди или топика в AWS-контуре, когда команда хочет управляемый сервис без собственного брокера.',
            'Kafka/RabbitMQ дают больше контроля, но требуют сопровождения. Azure Service Bus или Google Pub/Sub выбираются в соответствующих облаках.',
            'Нужны IAM-права, DLQ, visibility timeout, FIFO/standard выбор, лимиты облака, стоимость и мониторинг задержек.'),
        'azure_service_bus': ('Azure Service Bus',
            'Подходит для управляемой очереди/топика в Microsoft Azure, особенно если уже используется Azure AD, Logic Apps или корпоративный Microsoft-контур.',
            'RabbitMQ/Kafka требуют отдельного сопровождения. AWS SNS/SQS или Google Pub/Sub выбираются в других облаках. Redis queue слабее для критичной enterprise-очереди.',
            'Нужны namespace, queue/topic/subscription, dead-letter queue, lock duration, retry policy, RBAC и мониторинг.'),
        'gcp_pubsub': ('Google Pub/Sub',
            'Подходит для управляемой облачной pub/sub-интеграции в Google Cloud с автоматическим масштабированием подписчиков.',
            'Kafka даёт больше контроля над партициями и retention, но требует сопровождения. AWS/Azure варианты выбираются в своих облаках.',
            'Нужны topic, subscription, ack deadline, dead-letter topic, ordering key при необходимости, IAM и контроль backlog.'),
        'redis_streams': ('Redis Streams',
            'Подходит для лёгкого потока событий или задач внутри контура, когда уже используется Redis и требования к долговременному хранению ниже, чем у Kafka.',
            'Kafka надёжнее для долгого event log и масштабной повторной обработки. RabbitMQ удобнее для сложной маршрутизации задач. Redis cache не является очередью событий.',
            'Нужны consumer group, контроль pending entries, политика обрезки stream и понимание настроек сохранности Redis.'),
        'redis_queue': ('Redis как короткая очередь задач',
            'Подходит для простых фоновых задач с коротким сроком жизни, где допустимы ограничения Redis.',
            'RabbitMQ надёжнее для критичных task queue. Kafka лучше для событий и replay. БД-таблица проще, но хуже по производительности очереди.',
            'Нужны TTL, повторные попытки, обработка зависших задач и понимание риска потери при неверной настройке persistence.'),
        'queue': ('Очередь сообщений, брокер пока не выбран',
            'Подходит как нейтральное решение, когда известно, что нужна асинхронная очередь, но конкретный брокер ещё не утверждён.',
            'REST не подходит для отложенной обработки. Kafka/RabbitMQ/Redis выбираются позже по требованиям: event log, маршрутизация, надёжность, нагрузка и стоимость эксплуатации.',
            'Нужно отдельно выбрать брокер, определить модель подтверждения, лимит повторов, очередь ошибок и владельца разбора.'),
        'mqtt': ('MQTT',
            'Подходит для устройств, датчиков и IoT-сценариев, где важны лёгкий протокол, темы сообщений и разные уровни гарантии доставки.',
            'REST тяжелее для частых сообщений от устройств. Kafka может принять поток дальше внутри платформы, но не всегда удобна как протокол подключения устройств.',
            'Нужны topic-структура, QoS, идентификация устройства, контроль повторов, управление сессиями и защита канала.'),
        'webhook': ('Входящий веб-вызов',
            'Подходит, когда внешняя система сама присылает результат или статус в наш HTTP endpoint.',
            'Kafka/RabbitMQ нельзя требовать от партнёра, если он работает через HTTP. Polling хуже, потому что создаёт лишнюю нагрузку и задержку.',
            'Нужны подпись запроса, защита от повторов, окно времени, дедупликация и безопасное логирование без ПДн.'),
        'callback': ('Обратный вызов',
            'Подходит для позднего результата от внешней системы, когда исходный запрос уже завершён, а финальный статус приходит отдельно.',
            'Синхронный REST хуже, если внешний процесс долгий. Kafka/RabbitMQ подходят внутри нашего контура, но не всегда доступны партнёру. Batch слишком медленный для оперативного статуса.',
            'Нужны внешний requestId, подпись, дедупликация, статусная модель и ручной разбор неизвестных статусов.'),
        'websocket': ('WebSocket',
            'Подходит для двустороннего онлайн-канала, где сервер и клиент обмениваются сообщениями в рамках открытого соединения.',
            'SSE проще для однонаправленных уведомлений от сервера клиенту. REST требует частых опросов. Kafka/RabbitMQ не являются клиентским онлайн-каналом.',
            'Нужны heartbeat, переподключение, лимит соединений, авторизация сессии, backpressure и стратегия доставки пропущенных сообщений.'),
        'sse': ('Server-Sent Events',
            'Подходит для однонаправленного потока уведомлений от сервера клиенту поверх HTTP, когда клиенту не нужно отправлять сообщения назад по тому же каналу.',
            'WebSocket нужен для двустороннего обмена. REST polling создаёт лишнюю нагрузку. Брокер сообщений может быть внутри, но не заменяет клиентский поток.',
            'Нужны last-event-id, переподключение, лимит соединений, контроль частоты событий и fallback для клиентов без поддержки SSE.'),
        'sftp': ('SFTP',
            'Подходит для защищённого файлового обмена с legacy или внешним контрагентом, когда API недоступен или запрещён регламентом.',
            'REST/gRPC удобнее для оперативных запросов, но не подходят, если партнёр работает только файлами. Kafka/RabbitMQ обычно не доступны между организациями без отдельного соглашения.',
            'Нужны имя файла, контрольная сумма, идентификатор пакета, журнал загрузки, карантин ошибок и повторная обработка файла.'),
        'file': ('Файловая передача',
            'Подходит для пакетной передачи документов или больших наборов данных, когда процесс не требует мгновенного ответа.',
            'REST неудобен для больших файлов и массовой загрузки. Kafka не должна переносить тяжёлые документы внутри события. Object storage лучше для хранения больших файлов, а file — для факта передачи.',
            'Нужны контрольная сумма, размер, тип файла, антивирусная проверка, карантин и журнал строк/документов.'),
        'object_storage': ('Объектное хранилище',
            'Подходит для хранения больших файлов, документов, сканов и вложений, когда в сообщениях нужно передавать только ссылку.',
            'БД не стоит нагружать большими бинарными файлами. Kafka/RabbitMQ не должны переносить тяжёлые документы. File/SFTP могут быть транспортом, но не обязательно удобным хранилищем.',
            'Нужны права доступа, срок хранения, шифрование, антивирусная проверка и запрет публичных ссылок без срока действия.'),
        'batch': ('Пакетная обработка',
            'Подходит для обработки по расписанию, сверки, загрузки периода или массовой операции, где допустима задержка.',
            'REST/gRPC не подходят для больших периодических объёмов. Kafka хороша для потока событий, но не всегда удобна для регламентной сверки периода.',
            'Нужны идентификатор задания, контрольная отметка загрузки, контроль количества записей, повторный запуск периода и отчёт расхождений.'),
        'cdc': ('Передача изменений из базы данных',
            'Подходит для передачи зафиксированных изменений из операционной БД в аналитику или витрины без участия основного пользовательского потока.',
            'Прямые записи из сервиса в DWH создают связанность и риск замедлить бизнес-операцию. Batch проще, но даёт большую задержку. Kafka из приложения требует outbox-дисциплины.',
            'Нужны контроль позиции чтения, контроль отставания, совместимость схем, повторная синхронизация и сверка полноты.'),
        'etl': ('ETL/ELT-загрузка',
            'Подходит для загрузки и преобразования данных между источниками, аналитическим хранилищем и витринами.',
            'CDC передаёт изменения ближе к реальному времени, но не всегда заменяет сложные преобразования. Batch без ETL-правил не описывает качество и трансформации данных.',
            'Нужны расписание, mapping, контроль количества записей, quarantine ошибок, повторный запуск периода и журнал преобразований.'),
        'airflow': ('Airflow как оркестратор загрузок',
            'Подходит для управления зависимыми заданиями: загрузки, проверки, преобразования, ожидания файлов и повторные запуски.',
            'Один batch-скрипт проще, но быстро становится неуправляемым при зависимостях и SLA. Kafka не решает расписание и DAG-зависимости загрузок.',
            'Нужны DAG, расписание, retry, SLA, алерты, backfill/rerun и правила обработки частично выполненных загрузок.'),
        'spark': ('Spark',
            'Подходит для большой распределённой обработки данных: тяжёлые преобразования, агрегации, пересчёты истории и обработка больших файлов.',
            'Обычный batch проще для малых объёмов. ClickHouse/DWH лучше для запросов по уже подготовленным данным. Spark нужен именно для распределённого вычисления.',
            'Нужны партиционирование, checkpoint, контроль shuffle, повторный запуск, ресурсы кластера и контроль качества результата.'),
        'dbt': ('dbt как слой аналитических моделей',
            'Подходит для управляемых SQL-моделей, тестов качества, lineage и прозрачной сборки аналитических витрин.',
            'ETL-инструмент шире по загрузке данных, но dbt удобен для трансформаций внутри хранилища. Ручные SQL-скрипты хуже сопровождаются и тестируются.',
            'Нужны модели, тесты, freshness checks, documentation, lineage, окружения и правила релиза.'),
        'workflow_engine': ('Движок длительного процесса',
            'Подходит для долгого процесса с состояниями, таймерами, ожиданием внешних результатов и компенсационными действиями.',
            'Простая БД со статусами может хватить для короткого процесса, но становится хрупкой при таймерах, ожиданиях, retry и компенсациях. Kafka хранит события, но не заменяет orchestration state.',
            'Нужны модель состояний, таймеры, компенсации, история процесса, идемпотентность команд и правила ручного вмешательства.'),
        'bpm_engine': ('BPM/BPMN-движок',
            'Подходит, когда процесс содержит согласования, ручные бизнес-задачи, роли, SLA и эскалации.',
            'Workflow engine лучше для технической оркестрации. Простая таблица задач хуже, если бизнес хочет видеть и менять схему процесса.',
            'Нужны роли, формы задач, SLA, эскалации, аудит решений, версии процесса и правила миграции активных экземпляров.'),
        'cdn': ('CDN',
            'Подходит для быстрой раздачи статических файлов или публичных/полупубличных вложений пользователям в разных регионах.',
            'Object storage хранит файл, но не ускоряет доставку по географии. API-сервис не должен сам отдавать тяжёлую статику под высокой нагрузкой.',
            'Нужны cache-control, purge, срок жизни ссылки, приватный доступ, защита от утечки и стратегия обновления файлов.'),
        'auth_oidc': ('OAuth2/OIDC',
            'Подходит для единой авторизации пользователей, сервисов или партнёров с токенами, scopes и централизованной проверкой доступа.',
            'Самописная авторизация опаснее и сложнее в сопровождении. API Gateway может проверять токен, но источник идентичности и протокол всё равно нужны отдельно.',
            'Нужны scopes/claims, срок жизни токена, refresh-правила, аудит входа, ротация ключей и проверка прав на уровне действий.'),
        'vault': ('Vault/KMS для секретов и ключей',
            'Подходит, когда нужно безопасно хранить пароли, ключи подписи, сертификаты и секреты интеграций.',
            'Хранение секретов в конфигурации или БД повышает риск утечки. OAuth2/OIDC решает идентификацию, но не хранение технических секретов.',
            'Нужны политики доступа, ротация ключей, аудит чтения секретов, шифрование, разграничение окружений и emergency-процедуры.'),
        'observability': ('Наблюдаемость',
            'Подходит, чтобы видеть, где завис процесс: метрики, логи, трассировки, алерты и бизнес-события по состояниям.',
            'Обычные логи без корреляции не показывают сквозной процесс. Брокер/БД сами по себе не дают ответа, где именно потерялся запрос.',
            'Нужны correlationId, метрики задержки и ошибок, трассировка, алерты по очередям/лагу/ошибкам, дашборды и инструкции разбора.'),
    }
    technology, why, why_not, controls = decisions.get(ch, (
        ch or 'не определено',
        'Способ взаимодействия выбран из признаков процесса, но для него нет детального шаблона объяснения.',
        'Альтернативы нужно сравнить по задержке, надёжности, стоимости эксплуатации, требованиям к восстановлению и опыту команды.',
        'Нужно зафиксировать владельца, ограничения, отказные сценарии, тесты, метрики и правила эксплуатации.',
    ))
    reason = step.get('stack_reason') or ''
    if reason and reason not in why:
        why = f"{why} Дополнительный признак из конструктора: {_clean_sentence(reason)}."
    return {'technology': technology, 'why': why, 'why_not': why_not, 'controls': controls}

# v8.6.13: исправление отчёта по стеку.
# Важно: технология должна объяснять основной способ связи между участниками,
# а не служебную фиксацию состояния в БД. БД/outbox/inbox/аудит выводятся отдельно как компоненты надёжности.
_PREV_CHANNEL_DECISION_V8613 = _channel_decision


def _norm_ru_v8613(text):
    return str(text or '').lower()


def _is_external_v8613(name):
    v = _norm_ru_v8613(name)
    return any(x in v for x in ['внешн', 'партн', 'provider', 'api'])


def _is_analytics_v8613(name):
    v = _norm_ru_v8613(name)
    return any(x in v for x in ['аналит', 'dwh', 'data warehouse', 'витрин', 'озеро', 'data lake', 'lakehouse', 'clickhouse'])


def _is_storage_v8613(name):
    v = _norm_ru_v8613(name)
    return any(x in v for x in ['хранилищ', 'бд', 'база', 'database'])



def _explicit_channel_from_text_v8614(*parts):
    """Возвращает стек, если пользователь явно назвал технологию в участнике или связи.

    Это защищает отчёт от подмены: если участник называется RabbitMQ/Pulsar/ClickHouse,
    отчёт не должен автоматически заменять его на Kafka/БД/Batch.
    """
    v = ' '.join(_norm_ru_v8613(x) for x in parts if x)
    checks = [
        ('api gateway', 'api_gateway'), ('единая точка входа', 'api_gateway'), ('входной контур', 'api_gateway'),
        ('service mesh', 'service_mesh'), ('istio', 'service_mesh'), ('linkerd', 'service_mesh'),
        ('graphql', 'graphql'), ('odata', 'odata'), ('grpc', 'grpc'), ('soap', 'soap'), ('wsdl', 'soap'), ('старый веб-сервисный', 'soap'), ('веб-сервисный контракт', 'soap'),
        ('esb', 'esb'), ('интеграционная шина', 'esb'),
        ('pulsar', 'pulsar'), ('kafka', 'kafka'), ('rabbitmq', 'rabbitmq'), ('rabbit mq', 'rabbitmq'),
        ('activemq', 'activemq'), ('artemis', 'activemq'), ('ibm mq', 'ibm_mq'), ('nats', 'nats'),
        ('sns/sqs', 'sns_sqs'), ('sqs', 'sns_sqs'), ('azure service bus', 'azure_service_bus'),
        ('google pub/sub', 'gcp_pubsub'), ('pub/sub', 'gcp_pubsub'),
        ('redis streams', 'redis_streams'), ('redis stream', 'redis_streams'), ('redis queue', 'redis_queue'),
        ('mqtt', 'mqtt'),
        ('redis cache', 'redis_cache'), ('redis кэш', 'redis_cache'), ('memcached', 'memcached'),
        ('redis lock', 'redis_lock'), ('distributed lock', 'redis_lock'), ('распределённая блокировка', 'redis_lock'),
        ('mongodb', 'mongodb'), ('mongo', 'mongodb'), ('cassandra', 'cassandra'), ('scylladb', 'cassandra'), ('scylla', 'cassandra'),
        ('dynamodb', 'dynamodb'), ('key-value', 'dynamodb'), ('ключ-значение', 'dynamodb'),
        ('clickhouse', 'clickhouse'), ('data warehouse', 'data_warehouse'), ('dwh', 'data_warehouse'), ('аналитическое хранилище', 'data_warehouse'), ('аналитический контур', 'data_warehouse'),
        ('озеро данных', 'data_lake'), ('data lake', 'data_lake'), ('lakehouse', 'lakehouse'),
        ('реплика бд', 'read_replica'), ('read replica', 'read_replica'), ('шардирование', 'db_sharding'),
        ('поисковый индекс', 'search'), ('search index', 'search'), ('opensearch', 'search'), ('elasticsearch', 'search'),
        ('vector db', 'vector_db'), ('векторная бд', 'vector_db'),
        ('object storage', 'object_storage'), ('s3', 'object_storage'), ('minio', 'object_storage'), ('объектное хранилище', 'object_storage'),
        ('sftp', 'sftp'), ('cdc', 'cdc'), ('etl', 'etl'), ('elt', 'etl'), ('airflow', 'airflow'), ('spark', 'spark'), ('dbt', 'dbt'),
        ('workflow engine', 'workflow_engine'), ('temporal', 'workflow_engine'),
        ('bpm', 'bpm_engine'), ('bpmn', 'bpm_engine'), ('camunda', 'bpm_engine'),
        ('cdn', 'cdn'), ('oauth', 'auth_oidc'), ('oidc', 'auth_oidc'),
        ('vault', 'vault'), ('kms', 'vault'), ('наблюдаемость', 'observability'), ('observability', 'observability'),
    ]
    for marker, channel in checks:
        if marker in v:
            return channel
    # Нейтральные названия хранилища переводим в БД только когда это явно хранилище состояния,
    # а не внешняя/аналитическая/событийная система.
    if any(x in v for x in ['хранилище состояния', 'бд процесса', 'основная база данных']):
        return 'db'
    return ''

def _primary_channel_v8613(step):
    """Определяет основной способ связи между участниками.

    Не смешиваем основной канал связи и служебные компоненты. Например,
    связь «Сервис процесса -> Партнёр» не может быть основной БД только потому,
    что результат дополнительно сохраняется в БД.
    """
    ch = step.get('channel') or 'rest'
    name_raw = step.get('name') or ''
    src_raw = step.get('source_system') or ''
    sys_raw = step.get('system') or ''
    tgt_raw = step.get('target_system') or ''
    name = _norm_ru_v8613(name_raw)
    src = _norm_ru_v8613(src_raw)
    tgt = _norm_ru_v8613(tgt_raw)
    action = step.get('interaction_action') or ''
    timing = step.get('interaction_timing') or ('later' if not step.get('blocking') else 'sync')
    result = step.get('interaction_result') or ''

    # Явно названная платформа в получателе или названии шага имеет приоритет.
    # Важно: не ищем платформу во всей строке сразу, потому что источник может быть "Хранилище состояния",
    # а получатель — "Аналитическое хранилище". Иначе слово "хранилище состояния" ошибочно превращает
    # аналитическую связь в основную БД.
    target_explicit = _explicit_channel_from_text_v8614(tgt_raw, name_raw)
    system_explicit = _explicit_channel_from_text_v8614(sys_raw, name_raw)
    explicit = target_explicit or (system_explicit if system_explicit != 'db' else '')
    if explicit and explicit not in ('webhook', 'callback'):
        return explicit

    # Каналы, которые уже являются осмысленным основным способом связи, не надо менять только потому,
    # что шаг неблокирующий. Например, SFTP не должен превращаться в callback, а data_warehouse — в БД.
    stable_channels = {
        'sftp','file','object_storage','cdc','etl','batch','data_warehouse','data_lake','lakehouse','clickhouse',
        'search','vector_db','redis_cache','redis_lock','read_replica','db_sharding','mongodb','cassandra','dynamodb',
        'kafka','pulsar','rabbitmq','activemq','ibm_mq','nats','sns_sqs','azure_service_bus','gcp_pubsub',
        'redis_streams','redis_queue','queue','mqtt','websocket','sse','workflow_engine','bpm_engine',
        'auth_oidc','vault','observability','api_gateway','esb','service_mesh','graphql','odata','grpc','soap'
    }
    if ch in stable_channels:
        if ch == 'workflow_engine' and ('синхрон' in name or step.get('blocking')):
            return 'rest'
        if ch == 'db' and (_is_external_v8613(tgt_raw) or _is_analytics_v8613(tgt_raw)):
            pass
        else:
            return ch

    # Поздний результат от внешнего участника в наш сервис — входящий веб-вызов.
    # Поздний результат от партнёра после нашего исходящего запроса — обратный вызов.
    if timing == 'later' or action == 'wait_status':
        if _is_external_v8613(src_raw) and not _is_external_v8613(tgt_raw):
            return 'webhook'
        if _is_external_v8613(tgt_raw) or _is_external_v8613(src_raw):
            return 'callback'

    # Если конструктор сохранил семантику связи, она имеет приоритет.
    if action in ('save', 'update_status'):
        return 'db'
    if action == 'compare':
        return 'data_warehouse' if _is_analytics_v8613(step.get('target_system')) else 'batch'
    if action == 'file':
        return 'sftp' if _is_external_v8613(step.get('target_system')) else 'file'
    if action == 'notify_many':
        return 'kafka'
    if action in ('send_data', 'request_data', 'wait_status'):
        if _is_analytics_v8613(step.get('target_system')):
            return 'cdc' if _is_storage_v8613(step.get('source_system')) or _is_storage_v8613(step.get('system')) else 'data_warehouse'
        if timing == 'later' or action == 'wait_status':
            return 'callback' if _is_external_v8613(step.get('target_system')) or _is_external_v8613(step.get('source_system')) else 'queue'
        if _is_storage_v8613(step.get('target_system')) and result == 'save':
            return 'db'
        # Обычная связь между двумя участниками с немедленным результатом — это не БД,
        # даже если результат потом служебно сохраняется.
        return 'rest'

    # Защита от явных противоречий в старых отчётах/старых payload.
    if ch == 'db' and _is_external_v8613(step.get('target_system')):
        return 'callback' if not step.get('blocking') else 'rest'
    if ch == 'db' and _is_analytics_v8613(step.get('target_system')):
        return 'cdc' if _is_storage_v8613(step.get('source_system')) or _is_storage_v8613(step.get('system')) else 'data_warehouse'
    if ch == 'db' and any(x in name for x in ['переда', 'запрашивает', 'получает']) and not _is_storage_v8613(step.get('target_system')):
        return 'callback' if not step.get('blocking') else 'rest'
    if ch == 'workflow_engine' and ('синхрон' in name or step.get('blocking')):
        return 'rest'
    return ch


def _service_components_v8613(step, primary_channel):
    comps = []
    result = step.get('interaction_result') or ''
    ch = primary_channel
    if (step.get('writes_entity') or result == 'save') and ch != 'db':
        comps.append('БД процесса нужна как служебный компонент: в ней фиксируются статус, ключ идемпотентности и история шага. Это не основной способ связи с получателем.')
    if ch in ('kafka', 'pulsar', 'rabbitmq', 'activemq', 'ibm_mq', 'redis_streams', 'queue') and (step.get('writes_entity') or result == 'save'):
        comps.append('Для надёжной публикации после записи нужна таблица исходящих сообщений: запись в БД и подготовка сообщения должны происходить атомарно.')
    if ch in ('webhook', 'callback'):
        comps.append('Для входящего позднего результата нужна таблица входящих сообщений: она защищает от дублей и повторной доставки.')
    if ch in ('cdc', 'etl', 'batch', 'data_warehouse', 'data_lake', 'lakehouse', 'clickhouse'):
        comps.append('Нужна сверка полноты: источник и аналитический контур должны регулярно сравнивать количество, ключи и контрольные суммы.')
    return comps


def _channel_decision(step):
    primary = _primary_channel_v8613(step)
    fixed_step = dict(step)
    original = step.get('channel')
    fixed_step['channel'] = primary
    decision = dict(_PREV_CHANNEL_DECISION_V8613(fixed_step))
    service_components = _service_components_v8613(step, primary)
    decision['primary_channel'] = primary
    decision['original_channel'] = original
    decision['service_components'] = service_components
    if original and original != primary:
        tail = (
            'Служебная запись в БД не должна подменять канал взаимодействия с получателем.'
            if original == 'db'
            else 'Явно выбранная платформа или направление связи имеют приоритет над старым автоподбором.'
        )
        decision['correction'] = (
            f"В исходных данных шаг имел канал «{humanize_terms(original)}», но по смыслу связи между участниками основной способ должен быть «{decision.get('technology')}». "
            + tail
        )
    return decision


def _human_step_decision(step, decision, steps_by_order=None):
    order = step.get('order', '?')
    name = _clean_sentence(humanize_terms(step.get('name', 'действие без названия')))
    technology = humanize_terms(decision.get('technology', 'способ не определён'))
    src = humanize_terms(step.get('source_system') or 'источник не указан')
    executor = humanize_terms(step.get('system') or 'исполнитель не указан')
    tgt = humanize_terms(step.get('target_system') or 'получатель не указан')
    dependency = _dependency_label(step, steps_by_order)
    timing = 'результат нужен сразу или в рамках текущего шага' if step.get('blocking') else 'результат может прийти позже или обрабатывается отдельно'
    lines = []
    lines.append(f"**Что:** шаг {order} — «{name}». Основной способ взаимодействия: {technology}.")
    lines.append(f"**Где:** связь идёт от «{src}» к «{tgt}». Исполнитель шага: «{executor}». Шаг выполняется после: {dependency}. Характер связи: {timing}.")
    if decision.get('correction'):
        lines.append(f"**Важное исправление:** {humanize_terms(decision['correction'])}")
    lines.append(f"**Почему:** {humanize_terms(decision.get('why', '')).strip()}")
    lines.append(f"**Почему не другой вариант:** {humanize_terms(decision.get('why_not', '')).strip()}")
    if decision.get('service_components'):
        lines.append('**Служебные компоненты:** ' + ' '.join(humanize_terms(x) for x in decision['service_components']))
    lines.append(f"**Что проверить перед выпуском:** {humanize_terms(decision.get('controls', '')).strip()}")
    return lines

# ---------------------------------------------------------------------------
# v8.6.19: жёсткое разделение бизнес-цепочки, каналов связи, служебных компонентов
# и сквозных контролей. Это исправляет класс ошибок, когда отчёт пытался
# представить безопасность/наблюдаемость/аудит как обычные шаги бизнес-процесса,
# а получателя вроде DWH — как «способ взаимодействия».

_OLD_PRIMARY_CHANNEL_V8618 = _primary_channel_v8613
_OLD_CHANNEL_DECISION_V8618 = _channel_decision
_OLD_HUMAN_STEP_DECISION_V8618 = _human_step_decision

_ANALYTICS_CHANNELS_V8619 = {'cdc', 'etl', 'batch', 'airflow', 'spark', 'dbt', 'kafka', 'pulsar'}
_CONTROL_CHANNELS_V8619 = {'observability', 'vault', 'auth_oidc', 'cdn', 'service_mesh'}
_DATA_STORE_CHANNELS_V8619 = {'db', 'read_replica', 'db_sharding', 'mongodb', 'cassandra', 'dynamodb', 'clickhouse', 'data_warehouse', 'data_lake', 'lakehouse', 'object_storage'}
_BROKER_CHANNELS_V8619 = {'kafka', 'pulsar', 'rabbitmq', 'activemq', 'ibm_mq', 'nats', 'sns_sqs', 'azure_service_bus', 'gcp_pubsub', 'redis_streams', 'redis_queue', 'queue', 'mqtt'}


def _text_has_v8619(text, *needles):
    v = _norm_ru_v8613(text)
    return any(n in v for n in needles)


def _is_service_or_process_v8619(name):
    v = _norm_ru_v8613(name)
    return any(x in v for x in ['сервис', 'service', 'процесс', 'processor', 'api'])


def _is_manual_v8619(name):
    return _text_has_v8619(name, 'оператор', 'ручной', 'разбор', 'back-office', 'поддерж')


def _is_security_v8619(name):
    return _text_has_v8619(name, 'защит', 'маскир', 'секрет', 'ключ', 'vault', 'kms', 'oauth', 'oidc', 'авторизац', 'аутентиф', 'security')


def _is_observability_v8619(name):
    return _text_has_v8619(name, 'наблюдаем', 'observability', 'метрик', 'лог', 'трассиров', 'алерт', 'дашборд', 'где завис')


def _is_audit_v8619(name):
    return _text_has_v8619(name, 'audit', 'аудит', 'журнал аудита', 'audit journal', 'неизменяем')


def _is_cross_control_step_v8619(step):
    """Сквозной контроль не должен попадать в основную линейную бизнес-цепочку."""
    name = step.get('name') or ''
    src = step.get('source_system') or ''
    sys = step.get('system') or ''
    tgt = step.get('target_system') or ''
    ch = (step.get('channel') or '').lower()
    joined = ' '.join([name, src, sys, tgt, ch])
    primary = _primary_channel_v8613(step)
    if primary in _CONTROL_CHANNELS_V8619:
        return True
    if primary in {'workflow_engine', 'bpm_engine'} and _text_has_v8619(joined, 'процесс долгий', 'состояни', 'согласован', 'ручные бизнес-задачи'):
        return True
    if _is_observability_v8619(joined) or _is_security_v8619(joined) or _is_audit_v8619(joined):
        return True
    # Сервис сам в себя ради маскирования/аудита/авторизации — это контроль, а не бизнес-связь.
    if (src == tgt or sys == tgt or src == sys) and _text_has_v8619(name, 'маскир', 'секрет', 'авторизац', 'аудит', 'наблюдаем'):
        return True
    return False


def _is_analytics_target_v8619(step):
    return _is_analytics_v8613(step.get('target_system')) or _text_has_v8619(step.get('name'), 'аналит', 'витрин', 'dwh', 'data warehouse', 'озеро данных', 'clickhouse')


def _is_outbound_external_v8619(step):
    return _is_external_v8613(step.get('target_system')) and not _is_external_v8613(step.get('source_system'))


def _is_inbound_external_v8619(step):
    return _is_external_v8613(step.get('source_system')) and not _is_external_v8613(step.get('target_system'))


def _primary_channel_v8613(step):
    """v8.6.19: основной канал выбирается по смыслу связи, а не по служебному получателю.

    Правила:
    - исходящий запрос партнёру — это не callback; callback/webhook является отдельным входящим шагом;
    - аналитическое хранилище — это получатель/контур, а не способ доставки;
    - observability/auth/vault/audit/masking — сквозные контроли, не основной бизнес-канал;
    - явно названный брокер/транспорт сохраняется, но явно названный получатель DWH не подменяет канал.
    """
    ch = (step.get('channel') or 'rest').lower()
    name_raw = step.get('name') or ''
    src_raw = step.get('source_system') or ''
    sys_raw = step.get('system') or ''
    tgt_raw = step.get('target_system') or ''
    name = _norm_ru_v8613(name_raw)
    action = step.get('interaction_action') or ''
    timing = step.get('interaction_timing') or ('later' if not step.get('blocking') else 'sync')
    result = step.get('interaction_result') or ''

    # Сквозные контроли классифицируем отдельно.
    if _is_observability_v8619(' '.join([name_raw, src_raw, sys_raw, tgt_raw])):
        return 'observability'
    if _text_has_v8619(' '.join([name_raw, src_raw, sys_raw, tgt_raw]), 'vault', 'kms', 'секрет', 'ключ'):
        return 'vault'
    if _text_has_v8619(' '.join([name_raw, src_raw, sys_raw, tgt_raw]), 'oauth', 'oidc', 'авторизац', 'аутентиф'):
        return 'auth_oidc'
    if _text_has_v8619(' '.join([name_raw, src_raw, sys_raw, tgt_raw]), 'audit journal', 'журнал аудита', 'аудит', 'неизменяем'):
        return 'db'

    # Явно выбранные транспортные/брокерные платформы сохраняем.
    explicit_target = _explicit_channel_from_text_v8614(tgt_raw, name_raw)
    explicit_system = _explicit_channel_from_text_v8614(sys_raw, name_raw)
    explicit_name = _explicit_channel_from_text_v8614(name_raw)
    explicit = explicit_name or explicit_target or explicit_system

    # DWH/Data Lake/ClickHouse/Object Storage являются целевыми контурами. Если это именно получатель,
    # выбираем способ доставки, а не сам получатель как канал.
    if _is_analytics_target_v8619(step):
        if explicit_target == 'clickhouse' and _text_has_v8619(name_raw, 'clickhouse', 'быстрая аналитика', 'большим таблиц'):
            return 'clickhouse'
        if explicit_name in _ANALYTICS_CHANNELS_V8619 or explicit_name == 'clickhouse':
            return explicit_name
        if ch in _ANALYTICS_CHANNELS_V8619 or ch == 'clickhouse':
            return ch
        if explicit_target in {'clickhouse', 'data_warehouse', 'data_lake', 'lakehouse'}:
            # Получатель указан явно; канал всё равно должен быть CDC/ETL/Batch, кроме случая явной аналитической платформы ClickHouse для быстрых запросов.
            if _is_storage_v8613(src_raw) or _is_storage_v8613(sys_raw):
                return 'cdc'
            if _text_has_v8619(name_raw, 'свер', 'регуляр', 'период', 'batch', 'пакет'):
                return 'batch'
            return 'etl'
        if _is_storage_v8613(src_raw) or _is_storage_v8613(sys_raw):
            return 'cdc'
        return 'etl'

    # Файлы/объектное хранилище.
    if explicit in {'sftp', 'file', 'object_storage'} or ch in {'sftp', 'file', 'object_storage'} or _text_has_v8619(name_raw, 'файл', 'документ', 'скан', 'вложен'):
        if explicit in {'object_storage'} or ch == 'object_storage' or _text_has_v8619(tgt_raw, 'object storage', 's3', 'minio', 'объектное'):
            return 'object_storage'
        if _is_external_v8613(tgt_raw) or explicit == 'sftp' or ch == 'sftp':
            return 'sftp'
        return 'file'

    # Входящий поздний результат от внешнего участника — это входящий веб-вызов.
    if _is_inbound_external_v8619(step) and (timing == 'later' or not step.get('blocking') or _text_has_v8619(name_raw, 'поздн', 'обратн', 'callback', 'статус')):
        return 'webhook'

    # Исходящий запрос/передача партнёру — НЕ callback. Callback будет отдельным входящим шагом.
    if _is_outbound_external_v8619(step):
        if explicit in {'soap', 'esb', 'api_gateway', 'sftp', 'file'}:
            return explicit
        if ch in {'soap', 'esb', 'api_gateway', 'sftp', 'file'}:
            return ch
        return 'rest'

    # Явно выбранные брокеры и быстрые внутренние транспорты.
    if explicit in _BROKER_CHANNELS_V8619 | {'grpc', 'graphql', 'odata', 'api_gateway', 'esb', 'service_mesh', 'redis_cache', 'redis_lock', 'search', 'vector_db', 'read_replica', 'db_sharding', 'mongodb', 'cassandra', 'dynamodb'}:
        return explicit

    if ch in _BROKER_CHANNELS_V8619 | {'grpc', 'graphql', 'odata', 'api_gateway', 'esb', 'service_mesh', 'redis_cache', 'redis_lock', 'search', 'vector_db', 'read_replica', 'db_sharding', 'mongodb', 'cassandra', 'dynamodb'}:
        return ch

    # Семантика действия.
    if action in ('save', 'update_status') or _text_has_v8619(name_raw, 'сохраня', 'обновить статус', 'фиксир'):
        return 'db'
    if action == 'compare' or _text_has_v8619(name_raw, 'свер'):
        return 'batch'
    if action == 'notify_many' or _text_has_v8619(name_raw, 'опубликовать событие', 'рассыл', 'многим', 'журнал событий'):
        if explicit in {'pulsar', 'kafka', 'rabbitmq', 'nats'}:
            return explicit
        return 'kafka'
    if _text_has_v8619(name_raw, 'очередь задач', 'фоновую работу', 'worker', 'обработчик'):
        if explicit in {'rabbitmq', 'activemq', 'ibm_mq', 'sns_sqs', 'azure_service_bus', 'redis_queue'}:
            return explicit
        return 'rabbitmq'
    if _text_has_v8619(name_raw, 'быстро получить ответ', 'низкой задержк'):
        return 'grpc'

    # Если целевой участник — хранилище состояния, это БД. Если нет — не подменяем связь БД.
    if _is_storage_v8613(tgt_raw) and not _is_external_v8613(tgt_raw) and not _is_analytics_v8613(tgt_raw):
        return 'db'

    # Последняя защита от старого автоподбора: БД не может быть основным каналом внешней/аналитической связи.
    if ch == 'db' and (_is_external_v8613(tgt_raw) or _is_analytics_v8613(tgt_raw)):
        return 'rest'
    if ch == 'workflow_engine' and (step.get('blocking') or _text_has_v8619(name_raw, 'синхрон', 'ответ сразу')):
        return 'rest'
    return ch or 'rest'


def _service_components_v8613(step, primary_channel):
    comps = []
    result = step.get('interaction_result') or ''
    name = step.get('name') or ''
    ch = primary_channel
    if (step.get('writes_entity') or result == 'save') and ch != 'db':
        comps.append('БД процесса нужна как служебный компонент: она фиксирует состояние, ключ идемпотентности и историю шага. Это служебная запись, а не основной канал связи с получателем.')
    if ch in _BROKER_CHANNELS_V8619 and (step.get('writes_entity') or result == 'save' or _text_has_v8619(name, 'событие', 'публиков')):
        comps.append('Если перед публикацией меняется состояние в БД, нужна таблица исходящих сообщений: запись и подготовка сообщения должны быть атомарными.')
    if ch in ('webhook', 'callback'):
        comps.append('Для позднего входящего результата нужна таблица входящих сообщений: она защищает от дублей и повторной доставки.')
    if ch in _ANALYTICS_CHANNELS_V8619 | {'data_warehouse', 'data_lake', 'lakehouse', 'clickhouse'}:
        comps.append('Нужна сверка полноты между источником и аналитическим контуром: количество, ключи, контрольные суммы и отчёт расхождений.')
    if _is_outbound_external_v8619(step) and not step.get('blocking'):
        comps.append('Если партнёр вернёт результат позже, нужен отдельный входящий шаг: партнёр присылает статус в сервис процесса с подписью и дедупликацией.')
    return comps


def _channel_decision(step):
    primary = _primary_channel_v8613(step)
    fixed_step = dict(step)
    original = step.get('channel')
    fixed_step['channel'] = primary
    decision = dict(_PREV_CHANNEL_DECISION_V8613(fixed_step))
    # Не даём старому generic-описанию маскировать аналитические каналы.
    if primary == 'etl':
        decision.update({
            'technology': 'ETL/ELT-загрузка',
            'why': 'Подходит для передачи данных в аналитический контур с преобразованием, контролем качества и подготовкой витрин.',
            'why_not': 'Операционная БД является источником данных, но не способом доставки в аналитику. Прямая запись сервиса в DWH повышает связанность. CDC лучше для передачи изменений почти в реальном времени, Batch — для регламентной периодической загрузки.',
            'controls': 'Нужны правила преобразования, контроль количества записей, журнал загрузки, карантин ошибок, повторный запуск периода и сверка с источником.',
        })
    if primary == 'cdc':
        decision.update({
            'technology': 'Передача изменений из базы данных',
            'why': 'Подходит, когда данные уже зафиксированы в операционной БД и их нужно передавать в аналитический контур без замедления основного процесса.',
            'why_not': 'Прямая запись в DWH из бизнес-сервиса связывает операционный процесс с аналитикой. Batch проще, но даёт большую задержку. Событие из приложения требует строгой outbox-дисциплины.',
            'controls': 'Нужны контроль позиции чтения, контроль отставания, совместимость схем, повторная синхронизация и сверка полноты.',
        })
    decision['primary_channel'] = primary
    decision['original_channel'] = original
    decision['service_components'] = _service_components_v8613(step, primary)
    if original and original != primary:
        if original == 'db':
            tail = 'Служебная запись в БД не должна подменять канал взаимодействия с получателем.'
        elif original in {'callback', 'webhook'} and _is_outbound_external_v8619(step):
            tail = 'Исходящая передача партнёру и входящий поздний результат — это разные связи. Обратный результат нужно показывать отдельным входящим шагом.'
        elif original in {'data_warehouse', 'clickhouse', 'data_lake', 'lakehouse'}:
            tail = 'Аналитический контур является получателем данных. Способ доставки нужно выбирать отдельно: CDC, ETL/ELT, Batch или поток событий.'
        else:
            tail = 'Выбор уточнён по смыслу связи между участниками.'
        decision['correction'] = f"В исходных данных шаг имел канал «{humanize_terms(original)}», но по смыслу связи основной способ должен быть «{decision.get('technology')}». {tail}"
    return decision


def _route_label_v8619(step):
    src = humanize_terms(step.get('source_system') or 'источник не указан')
    tgt = humanize_terms(step.get('target_system') or 'получатель не указан')
    executor = humanize_terms(step.get('system') or 'исполнитель не указан')
    return src, tgt, executor


def _human_step_decision(step, decision, steps_by_order=None):
    order = step.get('order', '?')
    name = _clean_sentence(humanize_terms(step.get('name', 'действие без названия')))
    technology = humanize_terms(decision.get('technology', 'способ не определён'))
    src, tgt, executor = _route_label_v8619(step)
    dependency = _dependency_label(step, steps_by_order)
    timing = 'результат нужен сразу или в рамках текущего шага' if step.get('blocking') else 'результат может прийти позже или обрабатывается отдельно'
    lines = []
    lines.append(f"**Что:** шаг {order} — «{name}». Основной способ взаимодействия: {technology}.")
    lines.append(f"**Где:** связь идёт от «{src}» к «{tgt}». Исполнитель: «{executor}». Выполняется после: {dependency}. Характер связи: {timing}.")
    if decision.get('correction'):
        lines.append(f"**Важное исправление:** {humanize_terms(decision['correction'])}")
    lines.append(f"**Почему:** {humanize_terms(decision.get('why', '')).strip()}")
    lines.append(f"**Почему не другой вариант:** {humanize_terms(decision.get('why_not', '')).strip()}")
    if decision.get('service_components'):
        lines.append('**Служебные компоненты:** ' + ' '.join(humanize_terms(x) for x in decision['service_components']))
    lines.append(f"**Что проверить перед выпуском:** {humanize_terms(decision.get('controls', '')).strip()}")
    return lines


def _human_control_decision_v8619(step, decision, steps_by_order=None):
    order = step.get('order', '?')
    name = _clean_sentence(humanize_terms(step.get('name', 'контроль без названия')))
    technology = humanize_terms(decision.get('technology', 'контроль не определён'))
    src, tgt, executor = _route_label_v8619(step)
    scope = 'весь процесс' if _is_observability_v8619(step.get('name')) or _is_security_v8619(step.get('name')) else f'связь «{src} → {tgt}»'
    return [
        f"**Что:** контроль «{name}». Технический компонент: {technology}.",
        f"**Где:** применяется не как очередной бизнес-шаг, а как сквозной контроль на область: {scope}. Ответственный исполнитель: «{executor}».",
        f"**Почему:** {humanize_terms(decision.get('why', '')).strip()}",
        f"**Почему не другой вариант:** {humanize_terms(decision.get('why_not', '')).strip()}",
        f"**Что проверить перед выпуском:** {humanize_terms(decision.get('controls', '')).strip()}",
    ]


def _split_steps_v8619(steps):
    main, controls = [], []
    for st in steps:
        (controls if _is_cross_control_step_v8619(st) else main).append(st)
    return main, controls


def _build_process_table_v8619(out, steps, steps_by_order):
    out.append('| Шаг | Связь | Основной способ | Почему выбрано | Обязательные условия |')
    out.append('|---|---|---|---|---|')
    for step in steps:
        decision = _channel_decision(step)
        src, tgt, executor = _route_label_v8619(step)
        title = f"{step.get('order', '?')}. {_clean_sentence(humanize_terms(step.get('name', 'действие')))}"
        link = f"{src} → {tgt}. Исполнитель: {executor}."
        out.append(f"| {title} | {link} | {humanize_terms(decision['technology'])} | {humanize_terms(decision['why'])} | {humanize_terms(decision['controls'])} |")


_OLD_MARKDOWN_REPORT_V8618 = markdown_report

def markdown_report(res):
    """v8.6.19: отчёт с разделением основной цепочки и сквозных контролей."""
    m = res['model']['meta']
    v = res['verdict']
    comp = res.get('completeness') or {'summary': 'Полнота вводных не рассчитана.', 'missing': []}
    gates = res.get('quality_gates') or {'readiness': 'не рассчитано', 'gates': []}
    checklist = res.get('checklist') or {'items': [], 'counters': {}}
    groups = _finding_groups(res)
    steps_by_order = {int(st.get('order')): st for st in res['model']['steps'] if str(st.get('order', '')).isdigit()}
    main_steps, control_steps = _split_steps_v8619(res['model']['steps'])
    out = []
    a = out.append

    a(f"# Архитектурный разбор: {m['name']}")
    a('')
    grouped_counts = v.get('group_counts') or {}
    if grouped_counts:
        a(f"**Итоговый вывод:** {v['verdict']} Оценка архитектурной готовности: {v['score']}/10. "
          f"Найдено классов рисков: критичных — {grouped_counts.get('critical', 0)}, "
          f"высоких — {grouped_counts.get('high', 0)}, средних — {grouped_counts.get('medium', 0)}. "
          f"Всего отдельных срабатываний правил: {sum(v['counts'].values())}.")
    else:
        a(f"**Итоговый вывод:** {v['verdict']} Оценка архитектурной готовности: {v['score']}/10.")
    a(f"**Готовность к промышленному запуску:** {gates.get('readiness', 'не рассчитано')}. **{comp.get('summary', '')}**")
    a('')

    what, where_text, why_text = _human_top_summary(res)
    a('## Короткий человеческий вывод')
    a('')
    a(f"**Что:** {what}")
    a(f"**Где:** {where_text}")
    a(f"**Почему:** {why_text}")
    a('')
    a('**Что делать дальше:** сначала исправьте противоречия в схеме и блокирующие риски, затем уточните недостающие вводные, после этого согласуйте стек по каждой связи и только потом переводите решение в постановку на разработку.')
    a('')
    if m.get('goal'):
        a(f"**Бизнес-цель:** {m['goal']}")
    a(f"**Основная сущность:** {m['entity']}. Деньги: {m['money']}. Регуляторика: {'да' if m['regulatory'] else 'нет'}. Клиентский сценарий: {'да' if m['customer_visible'] else 'нет'}.")
    if m.get('sla_ms'):
        a(f"**Целевое время ответа:** {m['sla_ms']} мс.")
    a('')

    a('## Почему выбраны технологии и способы взаимодействия')
    a('')
    a('### Объяснение по шагам')
    a('')
    a('## Основная цепочка взаимодействий')
    a('')
    a('В этот раздел попадают только бизнес-связи между участниками. Наблюдаемость, аудит, авторизация, секреты и маскирование вынесены ниже как сквозные контроли, чтобы они не искажали порядок процесса.')
    a('')
    if not main_steps:
        a('Основная цепочка не определена или все шаги были классифицированы как сквозные контроли.')
        a('')
    else:
        for step in main_steps:
            decision = _channel_decision(step)
            a(f"### Шаг {step.get('order', '?')}. {_clean_sentence(humanize_terms(step.get('name', 'действие без названия')))}")
            a('')
            for line in _human_step_decision(step, decision, steps_by_order):
                a(line)
            a('')

    if control_steps:
        a('## Сквозные контроли и служебные компоненты')
        a('')
        a('Эти пункты важны, но они не являются очередными бизнес-шагами. Они применяются поверх процесса или к группе связей.')
        a('')
        for step in control_steps:
            decision = _channel_decision(step)
            a(f"### Контроль {step.get('order', '?')}. {_clean_sentence(humanize_terms(step.get('name', 'контроль без названия')))}")
            a('')
            for line in _human_control_decision_v8619(step, decision, steps_by_order):
                a(line)
            a('')

    a('## Таблица решений по основной цепочке')
    a('')
    if main_steps:
        _build_process_table_v8619(out, main_steps, steps_by_order)
    else:
        a('Нет бизнес-шагов для таблицы.')
    a('')

    a('## Как читать предложенное решение')
    a('')
    a('Почему предлагается именно так: решение выбирается из смысла связи и уточнений пользователя. Почему нельзя просто не делать: без выбранных гарантий процесс может терять данные, создавать дубли или становиться неразбираемым при сбое. В строке «основной способ взаимодействия» указан канал связи между участниками: API, файл, очередь, поток событий, CDC или загрузка в аналитику. БД процесса, таблицы входящих и исходящих сообщений, аудит, секреты и наблюдаемость описываются отдельно как служебные компоненты и сквозные контроли. Они не должны подменять канал связи.')
    a('')

    a('## Контрольные проверки готовности к промышленному запуску')
    a('')
    if gates.get('gates'):
        a('| Проверка | Статус | Что мешает выпуску | Что нужно уточнить |')
        a('|---|---|---|---|')
        for gate in gates['gates']:
            fail = _join_items(gate.get('fail') or []) or '—'
            warn = _join_items(gate.get('warn') or []) or '—'
            a(f"| {gate['name']} | {STATUS_RU.get(gate['status'], gate['status'])} | {humanize_terms(fail)} | {humanize_terms(warn)} |")
    else:
        a('Контрольные проверки готовности не рассчитаны.')
    a('')

    a('## Какие вводные нужно уточнить')
    a('')
    if comp.get('missing'):
        a('| Приоритет | Область | Что нужно уточнить | Почему это важно |')
        a('|---|---|---|---|')
        for item in comp['missing']:
            a(f"| {item['priority']} | {humanize_terms(item['area'])} | {humanize_terms(item['question'])} | {humanize_terms(item['why'])} |")
    else:
        a('Критичных пропусков во вводных не найдено. Архитектурное ревью всё равно нужно.')
    a('')

    a('## Найденные риски и слабые места')
    a('')
    a('Риски описаны по схеме «что / где / почему / что сделать».')
    a('')
    if not groups:
        a('Структурных проблем не обнаружено. Это не отменяет ревью, контрактные проверки и нагрузочные тесты.')
    last_sev = None
    for group in groups:
        sev = group.get('severity')
        if sev != last_sev:
            a(f"### {SEVERITY_RU.get(sev, sev)}")
            a('')
            last_sev = sev
        title = humanize_terms(group.get('title'))
        a(f"#### {title}")
        a('')
        affected = _affected_lines(group, limit=4)
        where = '; '.join(humanize_terms(x) for x in affected) if affected else 'место не определено'
        count_note = f" затронуто мест: {group.get('count')}" if group.get('count') else ''
        a(f"**Что:** найден риск «{title}».{count_note}")
        a(f"**Где:** {where}.")
        if affected:
            a('**Затронутые места:** ' + '; '.join(humanize_terms(x) for x in affected))
        a(f"**Почему важно:** {humanize_terms(group.get('why', 'риск может привести к сбою процесса или потере управляемости.'))}")
        a(f"**Что нужно сделать:** {humanize_terms(group.get('fix', 'нужно уточнить правило обработки и закрыть риск до промышленного запуска.'))}")
        a('')

    a('## Обязательный архитектурный чек-лист')
    a('')
    if checklist.get('items'):
        a('| Область | Статус | Что проверяется | Как закрыть пункт |')
        a('|---|---|---|---|')
        for item in checklist['items'][:40]:
            a(f"| {humanize_terms(item['area'])} | {STATUS_RU.get(item['status'], item['status'])} | {_clean_sentence(humanize_terms(item['title']))}. {humanize_terms(item['check'])} | {humanize_terms(item['fix'])} |")
        if len(checklist['items']) > 40:
            a(f"| Приложение | Сокращено | В полном чек-листе ещё {len(checklist['items']) - 40} пунктов. | Используйте расширенный чек-лист при архитектурном ревью. |")
    else:
        a('Архитектурный чек-лист не рассчитан.')
    a('')

    a('## Карта процесса и последовательность взаимодействий')
    a('')
    a('```mermaid')
    a(res['diagrams']['flow'])
    a('```')
    a('')
    a('```mermaid')
    a(res['diagrams']['sequence'])
    a('```')
    a('')

    # Сценарии и приложения сохраняем, но не смешиваем с основной цепочкой.
    scenario = res.get('scenario') or {}
    a('## Сценарная основа для дальнейшей разработки')
    a('')
    if scenario:
        a('### Основной сценарий')
        a('')
        for st in scenario.get('main_flow', []):
            # Сквозные контроли не скрываем полностью, но явно помечаем как контроль.
            kind = 'сквозной контроль' if _is_cross_control_step_v8619(steps_by_order.get(int(st.get('order', 0)), {})) else 'бизнес-шаг'
            a(f"{st['order']}. **{humanize_terms(st['title'])}** ({kind})")
            a(f"   - Что происходит: {humanize_terms(st['what_happens'])}")
            a(f"   - Способ взаимодействия: {humanize_terms(st.get('channel_label', st.get('channel', 'не указан')))}.")
            a(f"   - Зависимость: {humanize_terms(st['depends_on'])}.")
            a(f"   - Результат: {humanize_terms(st['result'])}")
            a(f"   - При ошибке: {humanize_terms(st['failure_handling'])}")
        a('')
        if scenario.get('alternative_flows'):
            a('### Альтернативные сценарии')
            a('')
            for i, alt in enumerate(scenario.get('alternative_flows', []), 1):
                a(f"{i}. **{humanize_terms(alt['name'])}**")
                a(f"   - Когда возникает: {humanize_terms(alt['trigger'])}")
                a(f"   - Ожидаемый результат: {humanize_terms(alt['result'])}")
        a('')
    else:
        a('Сценарная основа не рассчитана.')
        a('')

    a('## Варианты архитектурного решения')
    a('')
    for alt in res.get('alternatives', []):
        a(f"### {humanize_terms(alt['name'])}")
        a(f"Почему предлагается именно так: {humanize_terms(alt.get('when', 'этот вариант закрывает часть найденных рисков.'))}")
        why_alt, why_not_alt = _alternative_rationale(alt)
        a(f"Почему нельзя просто не делать: {humanize_terms(why_not_alt)}")
        if alt.get('changes'):
            a('Что изменить:')
            for c in alt.get('changes', []):
                a(f"- {humanize_terms(c)}")
        a('')

    radar = res.get('detail_radar') or {'summary': 'Матрица деталей не рассчитана.', 'probes': []}
    a('## Матрица деталей, которые нельзя забыть')
    a('')
    a(humanize_terms(radar.get('summary', 'Матрица деталей не рассчитана.')))
    if radar.get('probes'):
        a('')
        a('| Область | Статус | Что проверить | Почему это важно | Как закрыть |')
        a('|---|---|---|---|---|')
        for item in radar['probes'][:40]:
            examples = ''
            if item.get('examples'):
                examples = ' Примеры: ' + '; '.join(item.get('examples') or []) + '.'
            a(f"| {humanize_terms(item['area'])} | {STATUS_RU.get(item['status'], item['status'])} | {_clean_sentence(humanize_terms(item['title']))}. {humanize_terms(item['question'])} | {humanize_terms(item['why'])} | {humanize_terms(item['how'])}{humanize_terms(examples)} |")
    a('')

    artifacts = res.get('artifacts') or {}
    a('## Готовность к выпуску')
    a('')
    if artifacts.get('definition_of_ready'):
        a('**Definition of Ready:**')
        for x in artifacts.get('definition_of_ready', []):
            a(f"- {humanize_terms(x)}")
    if artifacts.get('definition_of_done'):
        a('')
        a('**Definition of Done:**')
        for x in artifacts.get('definition_of_done', []):
            a(f"- {humanize_terms(x)}")
    a('')
    a('## Черновик контракта события')
    a('')
    contract = artifacts.get('event_contract_skeleton') or {}
    if contract:
        for k, val in contract.items():
            a(f"- **{k}:** {humanize_terms(val)}")
    else:
        a('Черновик контракта события не рассчитан.')
    a('')

    schema_sql = res.get('schema') or ''
    a('## Структура хранения')
    a('')
    if schema_sql:
        a('```sql')
        a(schema_sql)
        a('```')
    else:
        a('DDL не рассчитан.')
    a('')

    tests = res.get('tests') or []
    a('## Чек-лист проверок и тестов')
    a('')
    if tests:
        for t in tests:
            a(f"- {humanize_terms(t)}")
    else:
        a('Чек-лист тестов не рассчитан.')
    a('')

    a('## Итог')
    a('')
    a('Этот отчёт нужно читать как архитектурный черновик: он отделяет бизнес-цепочку от служебных компонентов и сквозных контролей, показывает основной канал связи по каждой связи и явно указывает, что нужно проверить перед промышленным запуском.')
    return '\n'.join(humanize_terms(x) for x in out)

# v8.6.19 дополнительная проверка отчёта на противоречия маршрутов.
def _schema_consistency_issues_v8619(steps):
    issues = []
    for st in steps:
        order = st.get('order', '?')
        name = st.get('name') or ''
        src = st.get('source_system') or ''
        tgt = st.get('target_system') or ''
        sys = st.get('system') or ''
        primary = _primary_channel_v8613(st)
        if _is_outbound_external_v8619(st) and primary in {'callback', 'webhook'}:
            issues.append((order, name, 'Исходящая связь с партнёром не должна быть оформлена как обратный вызов. Нужно разделить исходящий запрос и входящий поздний результат.'))
        if _is_analytics_target_v8619(st) and primary in {'db', 'data_warehouse', 'data_lake', 'lakehouse'}:
            issues.append((order, name, 'Получатель является аналитическим контуром, а способ доставки должен быть CDC, ETL/ELT, Batch или поток событий, а не сам получатель.'))
        if _is_observability_v8619(name) or _is_security_v8619(name) or _is_audit_v8619(name):
            if not _is_cross_control_step_v8619(st):
                issues.append((order, name, 'Шаг похож на сквозной контроль и не должен искажать основную последовательность бизнес-связей.'))
        if _text_has_v8619(name, 'быстро получить ответ', 'низкой задержк') and _is_analytics_v8613(src):
            issues.append((order, name, 'Для быстрого синхронного ответа источник выглядит подозрительно: аналитическое хранилище не должно случайно становиться инициатором gRPC-вызова.'))
        if src == tgt and not (_is_storage_v8613(tgt) or _is_audit_v8619(name) or _is_security_v8619(name)):
            issues.append((order, name, 'Источник и получатель совпадают. Проверьте, не потерян ли реальный участник связи.'))
    return issues

# Переопределяем markdown_report ещё раз, чтобы добавить блок проверки логики схемы без копирования всего тела.
_MARKDOWN_REPORT_V8619_BASE = markdown_report

def markdown_report(res):
    md = _MARKDOWN_REPORT_V8619_BASE(res)
    issues = _schema_consistency_issues_v8619(res['model']['steps'])
    if not issues:
        insert = "## Проверка логики схемы\n\nСхема не содержит очевидных противоречий между названием связи, участниками и выбранным основным способом взаимодействия.\n\n"
    else:
        lines = ["## Проверка логики схемы", "", "Перед использованием отчёта проверьте эти места: они могут означать ошибку в построении цепочки.", ""]
        for order, name, why in issues:
            lines.append(f"- Шаг {order} «{humanize_terms(name)}»: {why}")
        lines.append("")
        insert = "\n".join(lines)
    marker = "## Почему выбраны технологии и способы взаимодействия"
    if marker in md:
        md = md.replace(marker, insert + marker, 1)
    else:
        md += "\n\n" + insert
    return humanize_terms(md)

# ---------------------------------------------------------------------------
# v8.6.20: финальный аудит логики отчёта.
# Исправляет оставшиеся классы ошибок:
# - сквозные controls/аудит/маскирование не должны выглядеть как REST/БД-каналы;
# - подозрительный маршрут не должен получать уверенный стек;
# - исходящий запрос партнёру с поздним результатом должен объясняться как запуск внешнего процесса,
#   а не как обычный синхронный REST с финальным ответом;
# - язык отчёта должен быть русским, без машинных оборотов после замен терминов.

_BASE_HUMANIZE_V8620 = humanize_terms


def humanize_terms(text):
    out = _BASE_HUMANIZE_V8620(text)
    fixes = (
        ('требование к времени ответа', 'целевое время ответа'),
        ('Требование к времени ответа', 'Целевое время ответа'),
        ('требования к времени ответа', 'требования к целевому времени ответа'),
        ('требованием к времени ответа', 'целевым временем ответа'),
        ('Повторная попытка настроен', 'Повторные попытки настроены'),
        ('повторная попытка настроен', 'повторные попытки настроены'),
        ('Повторная попытка настроена', 'Повторные попытки настроены'),
        ('повторная попытка настроена', 'повторные попытки настроены'),
        ('Повторная попытка не создаёт', 'Повторные попытки не создают'),
        ('повторная попытка не создаёт', 'повторные попытки не создают'),
        ('Каждая повторная попытка, которая может привести к записи, должен', 'Каждая повторная попытка, которая может привести к записи, должна'),
        ('каждая повторная попытка, которая может привести к записи, должен', 'каждая повторная попытка, которая может привести к записи, должна'),
        ('Повторная обработка должен', 'Повторная обработка должна'),
        ('повторная обработка должен', 'повторная обработка должна'),
        ('Повторная обработка должен использовать', 'Повторная обработка должна использовать'),
        ('повторная обработка должен использовать', 'повторная обработка должна использовать'),
        ('Повторная обработка часто запускается', 'Повторная обработка часто запускается'),
        ('повторная обработкаed', 'повторно обработано'),
        ('очередь ошибочных сообщений count', 'количество сообщений в очереди ошибок'),
        ('повторная попытка count', 'количество повторных попыток'),
        ('повторная обработка success/failure', 'успешные и неуспешные повторные обработки'),
        ('status aging', 'возраст статуса'),
        ('промышленный запуск-инцидентов', 'инцидентов на промышленном запуске'),
        ('таблица входящих сообщений для дедупликации table', 'таблица входящих сообщений для дедупликации'),
        ('увеличивающаяся пауза между повторными попытками с случайный разброс паузы', 'увеличивающаяся пауза между повторными попытками со случайным разбросом'),
        ('экспоненциальный увеличивающаяся пауза', 'экспоненциальная увеличивающаяся пауза'),
        ('идентификатор сквозной связи или идентификатор трассировки', 'идентификатор сквозной связи или трассировки'),
        ('идентификатор отслеживания бизнес-процесса', 'идентификатором бизнес-процесса'),
        ('повторная обработка command', 'команда повторной обработки'),
        ('idempotent повторная обработка', 'идемпотентная повторная обработка'),
        ('reconciliation после повторная обработка', 'сверка после повторной обработки'),
        ('повторная доставка / ручной разбор', 'повторная доставка или ручной разбор'),
        ('quarantine ошибок', 'карантин ошибок'),
        ('retry только', 'повторные попытки только'),
        ('retry и компенсациях', 'повторных попытках и компенсациях'),
        ('retry и', 'повторные попытки и'),
        ('retry,', 'повторные попытки,'),
        ('retry.', 'повторные попытки.'),
        ('timeout', 'таймаут'),
        ('Timeout', 'Таймаут'),
    )
    for old, new in fixes:
        out = out.replace(old, new)
    return out


def _route_error_v8620(step):
    name = step.get('name') or ''
    src = step.get('source_system') or ''
    tgt = step.get('target_system') or ''
    ch = (step.get('channel') or '').lower()
    if _text_has_v8619(name, 'быстро получить ответ', 'низкой задержк') and _is_analytics_v8613(src):
        return 'Для быстрого синхронного ответа источник выглядит ошибочным: аналитическое хранилище не должно становиться инициатором gRPC-вызова. Исправьте связь на «Сервис процесса → внутренний сервис» или вынесите аналитическую витрину в отдельный read-model.'
    if src == tgt and not (_is_storage_v8613(tgt) or _is_audit_v8619(name) or _is_security_v8619(name) or _is_observability_v8619(name)):
        return 'Источник и получатель совпадают. Скорее всего, потерян реальный участник связи.'
    if _is_analytics_target_v8619(step) and ch in {'data_warehouse', 'data_lake', 'lakehouse'}:
        return ''  # это не ошибка схемы, ниже канал будет заменён на способ доставки
    return ''


_PREV_PRIMARY_V8620 = _primary_channel_v8613
_PREV_CHANNEL_DECISION_V8620 = _channel_decision
_PREV_HUMAN_STEP_DECISION_V8620 = _human_step_decision
_PREV_HUMAN_CONTROL_DECISION_V8620 = _human_control_decision_v8619
_PREV_SCHEMA_ISSUES_V8620 = _schema_consistency_issues_v8619


def _primary_channel_v8613(step):
    name_raw = step.get('name') or ''
    joined = ' '.join([name_raw, step.get('source_system') or '', step.get('system') or '', step.get('target_system') or '', step.get('channel') or ''])
    if _route_error_v8620(step):
        return 'invalid_schema'
    if _is_audit_v8619(joined):
        return 'audit_journal'
    if _text_has_v8619(joined, 'маскир', 'чувствитель', 'пдн', 'персональн', 'data classification', 'tokenization') and not _text_has_v8619(joined, 'секрет', 'ключ', 'vault', 'kms'):
        return 'data_protection'
    return _PREV_PRIMARY_V8620(step)


def _channel_decision(step):
    primary = _primary_channel_v8613(step)
    if primary == 'invalid_schema':
        return {
            'technology': 'сначала исправить схему',
            'why': _route_error_v8620(step) or 'В связке участников есть противоречие, поэтому нельзя уверенно выбирать стек.',
            'why_not': 'Выбор gRPC, REST, брокера или БД поверх некорректной связи создаст ложное ощущение готовой архитектуры.',
            'controls': 'Верните шаг на этап проектирования связей, исправьте источник, получателя и смысл действия, затем повторно запустите проверку и подбор стека.',
            'primary_channel': primary,
            'original_channel': step.get('channel'),
            'service_components': [],
            'route_error': _route_error_v8620(step),
        }
    if primary == 'audit_journal':
        return {
            'technology': 'неизменяемый журнал аудита',
            'why': 'Подходит для юридически значимых действий: фиксирует факт, автора, время, причину изменения и связь с процессом без возможности тихо переписать историю.',
            'why_not': 'Обычная операционная БД может хранить записи, но без append-only правил, прав доступа и контроля изменений она не даёт достаточной доказательной базы. Брокер передаёт событие, но не заменяет аудит.',
            'controls': 'Нужны append-only модель, идентификатор сквозной связи, запрет изменения задним числом, срок хранения, разграничение доступа и аудит чтения журнала.',
            'primary_channel': primary,
            'original_channel': step.get('channel'),
            'service_components': [],
        }
    if primary == 'data_protection':
        return {
            'technology': 'защита и маскирование данных',
            'why': 'Подходит для чувствительных данных: классифицирует поля, маскирует лишнее в логах и событиях, ограничивает доступ и снижает риск утечки.',
            'why_not': 'REST, БД или брокер являются каналами/хранилищами, но сами по себе не решают классификацию ПДн, маскирование и правила доступа.',
            'controls': 'Нужны классификация полей, маскирование логов, запрет секретов в событиях, роли доступа, срок хранения и проверка тестовых стендов.',
            'primary_channel': primary,
            'original_channel': step.get('channel'),
            'service_components': [],
        }
    decision = dict(_PREV_CHANNEL_DECISION_V8620(step))
    # Для исходящего запроса партнёру с поздним результатом нельзя использовать обычное объяснение REST как финального синхронного ответа.
    if primary == 'rest' and _is_outbound_external_v8619(step) and (not step.get('blocking') or (step.get('interaction_timing') == 'later')):
        decision.update({
            'technology': 'REST API / HTTP-запрос к партнёру',
            'why': 'Подходит как исходящий запрос к партнёру для передачи данных или запуска внешней обработки. Технический ответ может подтвердить приём, а финальный бизнес-результат должен приходить отдельным входящим шагом.',
            'why_not': 'Обратный вызов не является исходящей отправкой: это отдельный входящий результат от партнёра. БД фиксирует статус процесса, но не передаёт данные партнёру. Брокер нельзя требовать от внешней организации без отдельного соглашения.',
            'controls': 'Нужны таймаут, внешний requestId, ключ идемпотентности, ограниченные повторы, проверка неизвестного результата и отдельный входящий callback/webhook для финального статуса.',
        })
    return decision


def _human_step_decision(step, decision, steps_by_order=None):
    lines = _PREV_HUMAN_STEP_DECISION_V8620(step, decision, steps_by_order)
    if decision.get('route_error'):
        warning = '**Статус шага:** требует исправления схемы до утверждения стека. Этот пункт нельзя считать готовым архитектурным решением.'
        return [warning] + lines
    return lines


def _human_control_decision_v8619(step, decision, steps_by_order=None):
    # У сквозного контроля не должно быть формулировки «основной способ взаимодействия».
    return _PREV_HUMAN_CONTROL_DECISION_V8620(step, decision, steps_by_order)


def _schema_consistency_issues_v8619(steps):
    issues = list(_PREV_SCHEMA_ISSUES_V8620(steps))
    seen = {(str(o), n, w) for o, n, w in issues}
    for st in steps:
        err = _route_error_v8620(st)
        if err:
            item = (st.get('order', '?'), st.get('name') or '', err)
            key = (str(item[0]), item[1], item[2])
            if key not in seen:
                issues.append(item)
                seen.add(key)
        primary = _primary_channel_v8613(st)
        if _is_audit_v8619(' '.join([st.get('name') or '', st.get('system') or '', st.get('target_system') or ''])) and primary == 'db':
            item = (st.get('order', '?'), st.get('name') or '', 'Аудит не должен объясняться как обычная основная БД. Нужен неизменяемый журнал аудита или append-only audit storage.')
            key = (str(item[0]), item[1], item[2])
            if key not in seen:
                issues.append(item)
                seen.add(key)
    return issues

